---
import '../styles/global.css';
import Home from '../components/Home.astro';
import Divider from '../components/Divider.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import Contact from '../components/Contact.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>My Portfolio</title>
	</head>
	<body class="font-sans leading-normal text-dark bg-light bg-[radial-gradient(circle_at_20%_50%,rgba(162,136,166,0.1)_0%,transparent_50%),radial-gradient(circle_at_80%_80%,rgba(187,155,176,0.1)_0%,transparent_50%),radial-gradient(circle_at_40%_20%,rgba(204,188,188,0.08)_0%,transparent_50%),linear-gradient(135deg,#f1e3e4_0%,rgba(241,227,228,0.8)_100%)] bg-fixed relative">
		<Home />
		<Divider type="light-to-dark" />
		<About />
		<Divider type="dark-to-light" />
		<Skills />
		<Divider type="light-to-dark" />
		<Projects />
		<Divider type="dark-to-light" />
		<Experience />
		<Divider type="light-to-dark" />
		<Contact />

		<script>
			window.onbeforeunload = function () {
				window.scrollTo(0, 0);
			};
		</script>
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}
</style>
