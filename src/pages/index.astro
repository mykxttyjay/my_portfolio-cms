---
import '@fontsource/dancing-script';
import '../styles/global.css';
import Home from '../components/Home.astro';
import Divider from '../components/Divider.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import Ribbon from '../components/Ribbon.astro';
import Contact from '../components/Contact.astro';
import Loader from '../components/Loader.astro';
import Footer from '../components/Footer.astro';
import profileData from '../data/profile.json';

const siteTitle = `${profileData.firstName} ${profileData.lastName} - Portfolio`;
const siteDescription = `${profileData.title} | ${profileData.intro}`;
const siteUrl = Astro.site || 'https://yourdomain.com'; // Update with your actual domain
const ogImage = new URL('/portfolio.png', siteUrl).href;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/portfolio.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{siteTitle}</title>
		<meta name="title" content={siteTitle} />
		<meta name="description" content={siteDescription} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:title" content={siteTitle} />
		<meta property="og:description" content={siteDescription} />
		<meta property="og:image" content={ogImage} />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={siteUrl} />
		<meta property="twitter:title" content={siteTitle} />
		<meta property="twitter:description" content={siteDescription} />
		<meta property="twitter:image" content={ogImage} />
		
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=EB+Garamond:ital,wght@0,400..800;1,400..800&display=swap" rel="stylesheet" />
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
	</head>
	<body>
		<Loader />
		<Home />
		<About />
		<Ribbon />
		<Skills />
		<Divider type="cream-to-cream" />
		<Projects />
		<Divider type="cream-reverse" />
		<Experience />
		<Contact />
		<Footer />

		<script>
			window.onbeforeunload = function () {
				window.scrollTo(0, 0);
			};
		</script>
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}
</style>
