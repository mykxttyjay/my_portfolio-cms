---
import '@fontsource/dancing-script';
import '../styles/global.css';
import Home from '../components/Home.astro';
import Divider from '../components/Divider.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import Ribbon from '../components/Ribbon.astro';
import Contact from '../components/Contact.astro';
import Loader from '../components/Loader.astro';
import Footer from '../components/Footer.astro';
import { getProfile } from '../lib/cms';

const profileData = await getProfile();
const siteTitle = `${profileData.firstName} ${profileData.lastName} - ${profileData.title} Portfolio`;
const siteDescription = `${profileData.firstName} ${profileData.lastName} is a ${profileData.title} specializing in ${profileData.specialization}. Explore my portfolio showcasing web development projects, design work, and technical expertise in creating user-centered digital experiences.`;
const siteKeywords = 'web developer, graphic designer, portfolio, web development, UI/UX design, frontend developer, Lapu-Lapu City, Cebu, Philippines, IT graduate';
const canonicalURL = 'https://angelmariesabido.vercel.app';
const ogImageURL = `${canonicalURL}/portfolio.png`;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary SEO Meta Tags -->
		<title>{siteTitle}</title>
		<meta name="description" content={siteDescription} />
		<meta name="keywords" content={siteKeywords} />
		<meta name="author" content={`${profileData.firstName} ${profileData.lastName}`} />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		<meta name="googlebot" content="index, follow" />
		<link rel="canonical" href={canonicalURL} />
		
		<!-- Favicon -->
		<link rel="icon" type="image/png" href="/portfolio.png" />
		<link rel="apple-touch-icon" href="/portfolio.png" />
		<meta name="theme-color" content="#8F1D21" />
		
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=EB+Garamond:ital,wght@0,400..800;1,400..800&display=swap" rel="stylesheet" />
		<link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
	</head>
	<body>
		<Loader />
		<main>
			<Home />
			<About />
			<Ribbon />
			<Skills />
			<Divider type="cream-to-cream" />
			<Projects />
			<Divider type="cream-reverse" />
			<Experience />
			<Contact />
		</main>
		<Footer />

		<script>
			window.onbeforeunload = function () {
				window.scrollTo(0, 0);
			};
		</script>
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}
</style>
