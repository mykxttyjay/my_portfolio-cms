---
import '@fontsource/dancing-script';
import '../styles/global.css';
import Home from '../components/Home.astro';
import Divider from '../components/Divider.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import Ribbon from '../components/Ribbon.astro';
import Contact from '../components/Contact.astro';
import Loader from '../components/Loader.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/portfolio.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Angel Marie Sabido - Portfolio</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=EB+Garamond:ital,wght@0,400..800;1,400..800&display=swap" rel="stylesheet" />
		<link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
	</head>
	<body>
		<Loader />
		<main>
			<Home />
			<About />
			<Ribbon />
			<Skills />
			<Divider type="cream-to-cream" />
			<Projects />
			<Divider type="cream-reverse" />
			<Experience />
			<Contact />
		</main>
		<Footer />

		<script>
			window.onbeforeunload = function () {
				window.scrollTo(0, 0);
			};
		</script>
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}
</style>
