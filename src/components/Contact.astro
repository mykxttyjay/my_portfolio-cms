---

<section class="contact" id="contact">
	<h2 class="heading">Contact <span>Me</span></h2>
	<div class="contact-container">
		<div class="contact-info">
			<div class="info-box">
				<div class="info-icon">
					<i class="fa-solid fa-envelope"></i>
				</div>
				<div>
					<h3>Email</h3>
					<p>sabidoangel.uc@gmail.com</p>
				</div>
			</div>
			<div class="info-box">
				<div class="info-icon">
					<i class="fa-solid fa-phone"></i>
				</div>
				<div>
					<h3>Phone</h3>
					<p>+63 954 291 7099</p>
				</div>
			</div>
			<div class="info-box">
				<div class="info-icon">
					<i class="fa-solid fa-location-dot"></i>
				</div>
				<div>
					<h3>Location</h3>
					<p>Lapu-Lapu City, Cebu 6015, Philippines</p>
				</div>
			</div>
		</div>
		<form action="#" class="contact-form">
			<div class="form-group">
				<input type="text" placeholder="Your Name" required />
				<i class="fa-solid fa-user"></i>
			</div>
			<div class="form-group">
				<input type="email" placeholder="Your Email" required />
				<i class="fa-solid fa-envelope"></i>
			</div>
			<div class="form-group">
				<input type="text" placeholder="Subject" required />
				<i class="fa-solid fa-pen"></i>
			</div>
			<div class="form-group">
				<textarea placeholder="Your Message" required></textarea>
				<i class="fa-solid fa-message"></i>
			</div>
			<button type="submit" class="btn">
				<span>Send Message</span>
				<i class="fa-solid fa-paper-plane"></i>
			</button>
		</form>
	</div>
</section>

<style>
	.contact {
		background: var(--light);
		padding: 5rem 0;
	}

	.contact-container {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 3rem;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.contact-info {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.info-box {
		background: var(--white);
		padding: 1.5rem 1.8rem;
		border-radius: 20px;
		display: flex;
		align-items: center;
		gap: 1.25rem;
		box-shadow: 0 10px 30px rgba(162, 136, 166, 0.06);
		border: 1px solid rgba(162, 136, 166, 0.03);
		transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), border-color 0.3s ease, box-shadow 0.3s ease;
	}

	.info-box:hover {
		transform: translateY(-5px);
		box-shadow: 0 15px 35px rgba(162, 136, 166, 0.12);
		border-color: rgba(162, 136, 166, 0.15);
	}

	.info-icon {
		width: 50px;
		height: 50px;
		background: var(--gradient);
		border-radius: 15px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--white);
		font-size: 1.2rem;
		flex-shrink: 0;
		box-shadow: 0 5px 15px rgba(162, 136, 166, 0.2);
		transition: transform 0.3s ease, border-radius 0.3s ease;
	}

	.info-box:hover .info-icon {
		transform: scale(1.1) rotate(10deg);
		border-radius: 50%;
	}

	.info-box h3 {
		font-size: 1.15rem;
		color: var(--dark);
		margin-bottom: 0.25rem;
		font-weight: 700;
	}

	.info-box p {
		color: #555;
		font-size: 0.95rem;
		font-weight: 500;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.form-group {
		position: relative;
	}

	.form-group input,
	.form-group textarea {
		width: 100%;
		padding: 1.1rem 1.1rem 1.1rem 3.2rem;
		border: 2px solid rgba(162, 136, 166, 0.25);
		border-radius: 15px;
		font-size: 1rem;
		font-family: inherit;
		transition: all 0.3s ease;
		background: var(--white);
		color: var(--dark);
		box-shadow: 0 2px 5px rgba(0, 0, 0, 0.02);
	}

	.form-group input:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: var(--primary);
		box-shadow: 0 8px 25px rgba(162, 136, 166, 0.15);
	}

	.form-group textarea {
		min-height: 150px;
		resize: vertical;
	}

	.form-group i {
		position: absolute;
		left: 1.25rem;
		top: 1.25rem;
		color: var(--primary);
		font-size: 1.1rem;
		transition: transform 0.3s ease, color 0.3s ease;
	}

	.form-group input:focus + i,
	.form-group textarea:focus + i {
		transform: scale(1.15);
		color: var(--primary);
	}

	.contact-form .btn {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		width: fit-content;
		padding: 1.1rem 2.2rem;
		border-radius: 50px;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.contact-form .btn i {
		transition: transform 0.3s ease;
	}

	.contact-form .btn:hover i {
		transform: translateX(3px) translateY(-2px);
	}
</style>
