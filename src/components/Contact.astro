---
import contactData from '../data/contact.json'

const { email, resumeLink } = contactData
---

<section id="contact" class="contact-section">
	<div class="contact-wrapper">
		<div class="envelope-container">
			<div class="envelope-back-panel">
				<svg viewBox="0 0 650 400" preserveAspectRatio="none">
					<path d="M 5,395 L 5,180 L 645,180 L 645,395 Z" fill="#EADFCB" stroke="#4A1215" stroke-width="4.5" stroke-linejoin="round" />
				</svg>
			</div>

			<div class="envelope-back-flap">
				<svg viewBox="0 0 650 181" preserveAspectRatio="none">
					<path d="M 5,180 L 325,5 L 645,180 Z" fill="#EADFCB" stroke="#4A1215" stroke-width="4.5" stroke-linejoin="round" />
				</svg>
			</div>

			<div class="contact-card-wrapper">
				<div class="contact-card">
					<h2 class="contact-title">Let's Connect</h2>
					<p class="contact-subtitle">I'd love to hear from you! Feel free to reach out via email or check out my resume.</p>
					
					<div class="contact-info">
						<div class="contact-item">
							<i class="fa-solid fa-envelope"></i>
							<div class="contact-details">
								<span class="contact-label">Email</span>
								<span class="contact-value">{email}</span>
							</div>
						</div>
						<div class="contact-item">
							<i class="fa-solid fa-file-lines"></i>
							<div class="contact-details">
								<span class="contact-label">Resume</span>
								<a href={resumeLink} target="_blank" rel="noopener noreferrer" class="resume-button">View My Resume</a>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="envelope-body">
				<svg class="envelope-front-svg" viewBox="0 0 650 220" preserveAspectRatio="none">
					<path d="M 5,215 L 5,5 L 325,120 L 645,5 L 645,215 Z" fill="#FCF8F2" stroke="#4A1215" stroke-width="4.5" stroke-linejoin="round" />
					<path d="M 5,215 L 325,120" stroke="#4A1215" stroke-width="4" stroke-linecap="round" />
					<path d="M 645,215 L 325,120" stroke="#4A1215" stroke-width="4" stroke-linecap="round" />
				</svg>
				
				<div class="wax-seal">
					<svg viewBox="0 0 120 120" class="wax-seal-svg">
						<path d="M 60,6 C 92,3 116,21 114,56 C 112,88 95,116 63,114 C 29,112 4,93 6,57 C 8,23 28,9 60,6 Z" fill="#8F1D21" stroke="#4A1215" stroke-width="4.5" stroke-linejoin="round" />
						<circle cx="60" cy="60" r="41" fill="#A12227" stroke="#4A1215" stroke-width="3" />
						<path d="M 33,33 A 28,28 0 0 1 87,33" fill="none" stroke="rgba(255, 255, 255, 0.2)" stroke-width="4.5" stroke-linecap="round" />
						<polygon points="60,36 66,50 81,50 69,60 74,75 60,66 46,75 51,60 39,50 54,50" fill="#5A0E11" stroke="#4A1215" stroke-width="3" stroke-linejoin="round" />
					</svg>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	const initContactScroll = () => {
		const contactSection = document.querySelector('.contact-section');
		const contactCard = document.querySelector('.contact-card');
		const footerSection = document.querySelector('footer');
		
		if (!contactSection || !contactCard) return;

		setTimeout(() => {
			contactCard.classList.add('scroll-transition');
		}, 3500);

		if (footerSection) {
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.target === footerSection) {
						if (entry.isIntersecting) {
							contactSection.classList.add('scroll-connect');
							contactCard.classList.add('card-hidden');
						} else {
							contactSection.classList.remove('scroll-connect');
							contactCard.classList.remove('card-hidden');
						}
					}
				});
			}, { threshold: 0.2 });

			observer.observe(footerSection);
		}
	};

	initContactScroll();
	document.addEventListener('astro:page-load', initContactScroll);
</script>

<style>
	.contact-section {
		padding: 0.4rem 2rem 0.4rem;
		background-color: #8F1D21;
		display: flex;
		justify-content: center;
		align-items: center;
		min-height: 90vh;
		position: relative;
		overflow: hidden;
	}

	.contact-section::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			url("data:image/svg+xml,%3Csvg viewBox='0 0 150 150' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.03' numOctaves='4' result='noise' seed='1' /%3E%3CfeColorMatrix in='noise' type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' fill='%23000000' filter='url(%23noiseFilter)' opacity='0.12'/%3E%3C/svg%3E");
		background-size: 150px 150px;
		pointer-events: none;
		z-index: 2;
		mix-blend-mode: overlay;
	}

	.contact-section::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: radial-gradient(circle at 50% 50%, rgba(155, 30, 34, 0.4) 0%, rgba(90, 14, 17, 0.85) 100%);
		pointer-events: none;
		z-index: 1;
	}

	.contact-wrapper {
		width: 100%;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3rem;
		position: relative;
		z-index: 10;
	}

	.envelope-container {
		width: 1100px;
		max-width: 95%;
		aspect-ratio: 650 / 400;
		position: relative;
	}

	.envelope-back-panel {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 8;
	}

	.envelope-back-panel svg {
		width: 100%;
		height: 100%;
		filter: drop-shadow(0 6px 12px rgba(0, 0, 0, 0.15));
	}

	.envelope-back-flap {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 45%;
		z-index: 9;
		transform-origin: 50% 100%;
		transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), z-index 0s 0s;
	}

	.contact-section.scroll-connect .envelope-back-flap {
		transform: rotateX(180deg);
		z-index: 20;
		transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.3s, z-index 0s 0.3s;
	}

	.envelope-back-flap svg {
		width: 100%;
		height: 100%;
		filter: drop-shadow(0 6px 12px rgba(0, 0, 0, 0.15));
	}

	.envelope-body {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 55%;
		z-index: 15;
		filter: drop-shadow(0 10px 25px rgba(0, 0, 0, 0.3));
		pointer-events: none;
	}

	.envelope-front-svg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	.wax-seal {
		width: 140px;
		height: 140px;
		position: absolute;
		top: 54.5%;
		left: 50%;
		transform: translate(-50%, -50%);
		filter: drop-shadow(0 6px 12px rgba(0, 0, 0, 0.35));
		z-index: 25;
		pointer-events: none;
	}

	.wax-seal-svg {
		width: 100%;
		height: 100%;
	}

	.contact-card-wrapper {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 10;
		clip-path: inset(-200% -20% 4% -20%);
	}

	.contact-card {
		background: #FCF8F2;
		border: 3.5px solid #4A1215;
		border-bottom: none;
		padding: 2.5rem 2.5rem 2rem;
		text-align: center;
		box-shadow: 0 -8px 20px rgba(0, 0, 0, 0.15);
		position: absolute;
		border-radius: 16px 16px 0 0;
		width: 92%;
		left: 4%;
		height: 100%;
		top: 60%;
		transform: translateY(0);
		animation: slide-up-contact 2.5s forwards;
		animation-delay: 1s;
	}

	@keyframes slide-up-contact {
		0% {
			top: 60%;
			animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
		}
		35% {
			top: 25%;
			animation-timing-function: linear;
		}
		65% {
			top: 25%;
			animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
		}
		100% {
			top: 15%;
		}
	}

	.contact-card.scroll-transition {
		transition: top 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
		animation: none;
	}

	.contact-section.scroll-connect .contact-card.scroll-transition {
		top: 60%;
	}

	.contact-card.scroll-transition:not(.card-hidden) {
		top: 15%;
	}

	.contact-title {
		font-family: 'Playfair Display', serif;
		font-size: 45px;
		font-weight: 700;
		font-style: italic;
		color: #4A1215;
		margin-bottom: 0.5rem;
		text-align: center;
	}

	.contact-subtitle {
		font-family: 'Poppins', sans-serif;
		font-size: 1.1rem;
		color: #666;
		text-align: center;
		margin-bottom: 2rem;
	}

	.contact-info {
		display: flex;
		flex-direction: row;
		gap: 2rem;
		max-width: 700px;
		margin: 0 auto;
	}

	.contact-item {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		padding: 1rem 1.5rem;
		background: #f9f8f5;
		border-radius: 8px;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
		text-align: left;
		flex: 1;
	}

	.contact-item:hover {
		transform: none;
		box-shadow: none;
	}

	.contact-item i {
		font-size: 1.8rem;
		color: #8b7355;
		min-width: 40px;
		text-align: center;
	}

	.contact-details {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.contact-label {
		font-family: 'Poppins', sans-serif;
		font-size: 0.9rem;
		font-weight: 600;
		color: #8b7355;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.contact-value {
		font-family: 'Poppins', sans-serif;
		font-size: 1.1rem;
		color: #2c2c2c;
	}

	.contact-link {
		color: #8b7355;
		text-decoration: none;
		transition: all 0.3s ease;
		font-weight: 600;
		position: relative;
		cursor: pointer;
		display: inline-block;
	}

	.contact-link:hover {
		color: #4A1215;
		text-decoration: underline;
		transform: translateX(4px);
	}

	.resume-button {
		display: inline-block;
		color: #8b7355;
		font-family: 'Poppins', sans-serif;
		font-size: 1.1rem;
		font-weight: 600;
		text-decoration: none;
		transition: color 0.3s ease;
		cursor: pointer;
	}

	.resume-button:hover {
		color: #4A1215;
		text-decoration: underline;
	}

	@media (max-width: 768px) {
		.contact-section {
			padding: 2rem 1rem;
		}

		.contact-card {
			padding: 2rem 1.5rem 1.5rem;
		}

		.envelope-container {
			max-width: 95%;
		}

		.wax-seal {
			width: 100px;
			height: 100px;
		}

		.contact-title {
			font-size: 2rem;
		}

		.contact-subtitle {
			font-size: 1rem;
			margin-bottom: 1.5rem;
		}

		.contact-info {
			flex-direction: column;
			gap: 1.2rem;
		}

		.contact-item {
			flex-direction: row;
			gap: 1rem;
			padding: 0.8rem 1rem;
		}

		.contact-item i {
			font-size: 1.5rem;
		}
	}

	@media (max-width: 480px) {
		.contact-card {
			padding: 1.5rem 1rem 1rem;
		}

		.wax-seal {
			width: 70px;
			height: 70px;
		}

		.contact-title {
			font-size: 1.75rem;
		}

		.contact-subtitle {
			font-size: 0.95rem;
		}

		.contact-item {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.75rem;
			padding: 0.75rem 1rem;
		}

		.contact-item i {
			font-size: 1.3rem;
		}

		.contact-value {
			font-size: 1rem;
		}
	}
</style>
