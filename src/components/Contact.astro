---
import { getEmDashCollection } from 'emdash';

let contactItems = [
	{
		platform: "Email",
		value: "sabidoangel.uc@gmail.com",
		icon: "fa-solid fa-envelope"
	},
	{
		platform: "Phone",
		value: "+63 954 291 7099",
		icon: "fa-solid fa-phone"
	},
	{
		platform: "Location",
		value: "Lapu-Lapu City, Cebu 6015, Philippines",
		icon: "fa-solid fa-location-dot"
	}
];

try {
	const { entries } = await getEmDashCollection('contact');
	if (entries && entries.length > 0) {
		contactItems = entries.map((entry) => {
			const platform = (entry.data?.platform as string) || "";
			const value = (entry.data?.value as string) || "";
			const icon = (entry.data?.icon as string) || "";
			return { platform, value, icon };
		});
	}
} catch (e) {
	console.error('Error fetching contacts from EmDash:', e);
}
---

<section class="contact" id="contact">
	<h2 class="heading">Contact <span>Me</span></h2>
	<div class="contact-container">
		<div class="contact-info">
			<div class="languages-section">
				<h3 class="languages-title">Languages</h3>
				<ul class="languages-list">
					<li>English – Advanced</li>
					<li>Filipino – Native</li>
				</ul>
			</div>
			{contactItems.map((item) => (
				<div class="info-box">
					<div class="info-icon">
						<i class={item.icon}></i>
					</div>
					<div>
						<h3>{item.platform}</h3>
						<p>{item.value}</p>
					</div>
				</div>
			))}
		</div>
		<form action="#" class="contact-form">
			<div class="form-group">
				<input type="text" placeholder="Your Name" required />
				<i class="fa-solid fa-user"></i>
			</div>
			<div class="form-group">
				<input type="email" placeholder="Your Email" required />
				<i class="fa-solid fa-envelope"></i>
			</div>
			<div class="form-group">
				<input type="text" placeholder="Subject" required />
				<i class="fa-solid fa-pen"></i>
			</div>
			<div class="form-group">
				<textarea placeholder="Your Message" required></textarea>
				<i class="fa-solid fa-message"></i>
			</div>
			<button type="submit" class="btn">
				<span>Send Message</span>
				<i class="fa-solid fa-paper-plane"></i>
			</button>
		</form>
	</div>
</section>

<style>
	.contact {
		background: #FEF9E1;
		padding: 5rem 0;
		position: relative;
		overflow: hidden;
	}

	.contact::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			url("data:image/svg+xml,%3Csvg viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' result='noise' seed='2' /%3E%3CfeColorMatrix in='noise' type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100' height='100' fill='%23000000' filter='url(%23noiseFilter)' opacity='0.08'/%3E%3C/svg%3E");
		background-size: 100px 100px;
		pointer-events: none;
		z-index: 0;
		mix-blend-mode: overlay;
	}

	.contact .heading {
		color: #A31D1D;
		position: relative;
		z-index: 1;
		font-family: 'Poppins', sans-serif;
		font-size: 3.5rem;
		font-weight: 900;
		letter-spacing: 0px;
		font-style: italic;
	}

	.contact .heading span {
		-webkit-text-fill-color: #A31D1D;
		color: #A31D1D;
	}

	.contact-container {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 3rem;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
		position: relative;
		z-index: 1;
	}

	.contact-info {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.languages-section {
		background: white;
		border: 2px solid #A31D1D;
		padding: 2rem;
		border-radius: 20px;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
	}

	.languages-title {
		font-size: 1.5rem;
		color: #A31D1D;
		margin-bottom: 1.5rem;
		font-weight: 700;
		font-style: italic;
	}

	.languages-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.languages-list li {
		color: #A31D1D;
		font-weight: 600;
		font-size: 1.1rem;
		display: flex;
		align-items: center;
		gap: 0.8rem;
	}

	.languages-list li::before {
		content: '•';
		color: #A31D1D;
		font-weight: bold;
		font-size: 1.5rem;
	}

	.info-box {
		background: white;
		border: 1px solid rgba(163, 29, 29, 0.1);
		padding: 1.5rem 1.8rem;
		border-radius: 20px;
		display: flex;
		align-items: center;
		gap: 1.25rem;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
		transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), border-color 0.3s ease, box-shadow 0.3s ease;
	}

	.info-box:hover {
		transform: translateY(-5px);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
		border-color: rgba(163, 29, 29, 0.2);
	}

	.info-icon {
		width: 50px;
		height: 50px;
		background: linear-gradient(135deg, #A31D1D 0%, #8B1515 100%);
		border: 1px solid rgba(163, 29, 29, 0.2);
		border-radius: 15px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		font-size: 1.2rem;
		flex-shrink: 0;
		box-shadow: 0 5px 15px rgba(163, 29, 29, 0.15);
		transition: transform 0.3s ease, border-radius 0.3s ease, background 0.3s ease, color 0.3s ease;
	}

	.info-box:hover .info-icon {
		transform: scale(1.1) rotate(10deg);
		border-radius: 50%;
		background: white;
		color: #A31D1D;
		border-color: transparent;
	}

	.info-box h3 {
		font-size: 1.15rem;
		color: #A31D1D;
		margin-bottom: 0.25rem;
		font-weight: 700;
	}

	.info-box p {
		color: #555;
		font-size: 0.95rem;
		font-weight: 500;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.form-group {
		position: relative;
	}

	.form-group input,
	.form-group textarea {
		width: 100%;
		padding: 1.1rem 1.1rem 1.1rem 3.2rem;
		border: 2px solid rgba(163, 29, 29, 0.2);
		border-radius: 15px;
		font-size: 1rem;
		font-family: inherit;
		transition: all 0.3s ease;
		background: white;
		color: #333;
		box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
	}

	.form-group input::placeholder,
	.form-group textarea::placeholder {
		color: #999;
	}

	.form-group input:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: #A31D1D;
		background: white;
		box-shadow: 0 8px 25px rgba(163, 29, 29, 0.15);
	}

	.form-group textarea {
		min-height: 150px;
		resize: vertical;
	}

	.form-group i {
		position: absolute;
		left: 1.25rem;
		top: 1.25rem;
		color: #A31D1D;
		font-size: 1.1rem;
		transition: transform 0.3s ease, color 0.3s ease;
	}

	.form-group input:focus + i,
	.form-group textarea:focus + i {
		transform: scale(1.15);
		color: #8B1515;
	}

	.contact-form .btn {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		width: fit-content;
		padding: 1.1rem 2.2rem;
		border-radius: 50px;
		transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
		background: linear-gradient(135deg, #A31D1D 0%, #8B1515 100%);
		color: white;
		box-shadow: 0 10px 25px rgba(163, 29, 29, 0.2);
		border: none;
	}

	.contact-form .btn:hover {
		transform: translateY(-3px);
		box-shadow: 0 15px 30px rgba(163, 29, 29, 0.3);
		background: linear-gradient(135deg, #8B1515 0%, #7A1010 100%);
	}

	.contact-form .btn i {
		transition: transform 0.3s ease;
	}

	.contact-form .btn:hover i {
		transform: translateX(3px) translateY(-2px);
	}
</style>
