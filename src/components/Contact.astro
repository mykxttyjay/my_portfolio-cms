---
import { getEmDashCollection } from 'emdash';

let contactItems = [
	{
		platform: "Email",
		value: "sabidoangel.uc@gmail.com",
		icon: "fa-solid fa-envelope"
	},
	{
		platform: "Phone",
		value: "+63 954 291 7099",
		icon: "fa-solid fa-phone"
	},
	{
		platform: "Location",
		value: "Lapu-Lapu City, Cebu 6015, Philippines",
		icon: "fa-solid fa-location-dot"
	}
];

try {
	const { entries } = await getEmDashCollection('contact');
	if (entries && entries.length > 0) {
		contactItems = entries.map((entry) => {
			const platform = entry.data.platform;
			const value = entry.data.value;
			const icon = entry.data.icon;
			return { platform, value, icon };
		});
	}
} catch (e) {
	console.error('Error fetching contacts from EmDash:', e);
}
---

<section class="contact" id="contact">
	<h2 class="heading">Contact <span>Me</span></h2>
	<div class="contact-container">
		<div class="contact-info">
			{contactItems.map((item) => (
				<div class="info-box">
					<div class="info-icon">
						<i class={item.icon}></i>
					</div>
					<div>
						<h3>{item.platform}</h3>
						<p>{item.value}</p>
					</div>
				</div>
			))}
		</div>
		<form action="#" class="contact-form">
			<div class="form-group">
				<input type="text" placeholder="Your Name" required />
				<i class="fa-solid fa-user"></i>
			</div>
			<div class="form-group">
				<input type="email" placeholder="Your Email" required />
				<i class="fa-solid fa-envelope"></i>
			</div>
			<div class="form-group">
				<input type="text" placeholder="Subject" required />
				<i class="fa-solid fa-pen"></i>
			</div>
			<div class="form-group">
				<textarea placeholder="Your Message" required></textarea>
				<i class="fa-solid fa-message"></i>
			</div>
			<button type="submit" class="btn">
				<span>Send Message</span>
				<i class="fa-solid fa-paper-plane"></i>
			</button>
		</form>
	</div>
</section>

<style>
	.contact {
		background: var(--primary);
		padding: 5rem 0;
	}

	.contact .heading {
		color: var(--white);
	}

	.contact .heading span {
		-webkit-text-fill-color: var(--accent);
		color: var(--accent);
	}

	.contact-container {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 3rem;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.contact-info {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.info-box {
		background: rgba(255, 255, 255, 0.08);
		backdrop-filter: blur(12px);
		border: 1px solid rgba(255, 255, 255, 0.15);
		padding: 1.5rem 1.8rem;
		border-radius: 20px;
		display: flex;
		align-items: center;
		gap: 1.25rem;
		box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1), 0 0 0 1px rgba(255, 255, 255, 0.05) inset;
		transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), border-color 0.3s ease, box-shadow 0.3s ease;
	}

	.info-box:hover {
		transform: translateY(-5px);
		box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(255, 255, 255, 0.1) inset;
		border-color: rgba(255, 255, 255, 0.25);
	}

	.info-icon {
		width: 50px;
		height: 50px;
		background: rgba(255, 255, 255, 0.15);
		border: 1px solid rgba(255, 255, 255, 0.2);
		border-radius: 15px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--white);
		font-size: 1.2rem;
		flex-shrink: 0;
		box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
		transition: transform 0.3s ease, border-radius 0.3s ease, background 0.3s ease, color 0.3s ease;
	}

	.info-box:hover .info-icon {
		transform: scale(1.1) rotate(10deg);
		border-radius: 50%;
		background: var(--white);
		color: var(--primary);
		border-color: transparent;
	}

	.info-box h3 {
		font-size: 1.15rem;
		color: var(--white);
		margin-bottom: 0.25rem;
		font-weight: 700;
	}

	.info-box p {
		color: rgba(255, 255, 255, 0.85);
		font-size: 0.95rem;
		font-weight: 500;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.form-group {
		position: relative;
	}

	.form-group input,
	.form-group textarea {
		width: 100%;
		padding: 1.1rem 1.1rem 1.1rem 3.2rem;
		border: 2px solid rgba(255, 255, 255, 0.15);
		border-radius: 15px;
		font-size: 1rem;
		font-family: inherit;
		transition: all 0.3s ease;
		background: rgba(255, 255, 255, 0.08);
		color: var(--white);
		box-shadow: 0 2px 5px rgba(0, 0, 0, 0.02);
	}

	.form-group input::placeholder,
	.form-group textarea::placeholder {
		color: rgba(255, 255, 255, 0.6);
	}

	.form-group input:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: var(--white);
		background: rgba(255, 255, 255, 0.12);
		box-shadow: 0 8px 25px rgba(255, 255, 255, 0.15);
	}

	.form-group textarea {
		min-height: 150px;
		resize: vertical;
	}

	.form-group i {
		position: absolute;
		left: 1.25rem;
		top: 1.25rem;
		color: rgba(255, 255, 255, 0.7);
		font-size: 1.1rem;
		transition: transform 0.3s ease, color 0.3s ease;
	}

	.form-group input:focus + i,
	.form-group textarea:focus + i {
		transform: scale(1.15);
		color: var(--white);
	}

	.contact-form .btn {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		width: fit-content;
		padding: 1.1rem 2.2rem;
		border-radius: 50px;
		transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
		background: var(--white);
		color: var(--primary);
		box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
		border: none;
	}

	.contact-form .btn:hover {
		transform: translateY(-3px);
		box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
		background: var(--light);
	}

	.contact-form .btn i {
		transition: transform 0.3s ease;
	}

	.contact-form .btn:hover i {
		transform: translateX(3px) translateY(-2px);
	}
</style>
