<section class="experience" id="experience">
	<div class="experience-content">
		<div class="experience-header">
			<h2 class="heading"><span>Experience</span></h2>
			<p class="experience-description">
				My professional journey includes hands-on experience in web development and design, 
				where I've collaborated with teams and clients to deliver impactful digital solutions. 
				From internships to freelance projects, each opportunity has shaped my approach to 
				problem-solving and strengthened my expertise in building user-centered apps.
			</p>
		</div>
		<div class="experience-container">
			<div class="experience-box">
				<div class="experience-header-row">
					<h3>Web Development Internship</h3>
					<p class="date">January 2026 - Present</p>
				</div>
				<p class="company">N-Compass TV</p>
			</div>
			<div class="experience-box">
				<div class="experience-header-row">
					<h3>Academy Technology Salesforce</h3>
					<p class="date">February 2026 - April 2026</p>
				</div>
				<p class="company">Accenture</p>
			</div>
		</div>
	</div>
</section>

