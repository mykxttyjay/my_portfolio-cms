	.experience-box h3 {
		font-size: 23px;
		color: #4A1215;
		margin-bottom: 0.8rem;
		font-weight: 700;
		font-family: 'Playfair Display', Georgia, serif;
		font-style: italic;
	}

	.experience-header-row {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		width: 100%;
