---
---

<section class="experience bg-light py-20" id="experience">
	<h2 class="heading text-4xl font-bold mb-12 text-center text-dark">
		Experience / <span class="gradient-text">OJT</span>
	</h2>
	<div class="experience-container grid grid-cols-[repeat(auto-fit,minmax(300px,1fr))] gap-10 max-w-[1000px] mx-auto px-8">
		<div class="experience-box bg-white p-10 px-8 rounded-3xl shadow-[0_10px_30px_rgba(162,136,166,0.06)] border border-primary/5 transition-all duration-[400ms] ease-[cubic-bezier(0.175,0.885,0.32,1.275)] flex flex-col items-start hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(162,136,166,0.12)] hover:border-primary/15">
			<div class="experience-icon w-[60px] h-[60px] bg-gradient-to-br from-primary to-secondary rounded-[20px] flex items-center justify-center text-white text-2xl mb-6 shadow-[0_8px_20px_rgba(162,136,166,0.2)] transition-all duration-300 group-hover:scale-110 group-hover:rotate-[8deg] group-hover:rounded-full">
				<i class="fa-solid fa-briefcase"></i>
			</div>
			<h3 class="text-[1.4rem] text-dark mb-4 font-bold">Web Development Internship</h3>
			<p class="text-[#555] leading-relaxed text-[0.95rem]">Assisted in developing web applications and gained hands-on experience in software development. Worked with modern frameworks and collaborated with senior developers.</p>
		</div>
		<div class="experience-box bg-white p-10 px-8 rounded-3xl shadow-[0_10px_30px_rgba(162,136,166,0.06)] border border-primary/5 transition-all duration-[400ms] ease-[cubic-bezier(0.175,0.885,0.32,1.275)] flex flex-col items-start hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(162,136,166,0.12)] hover:border-primary/15">
			<div class="experience-icon w-[60px] h-[60px] bg-gradient-to-br from-primary to-secondary rounded-[20px] flex items-center justify-center text-white text-2xl mb-6 shadow-[0_8px_20px_rgba(162,136,166,0.2)] transition-all duration-300 group-hover:scale-110 group-hover:rotate-[8deg] group-hover:rounded-full">
				<i class="fa-solid fa-laptop-code"></i>
			</div>
			<h3 class="text-[1.4rem] text-dark mb-4 font-bold">Freelance Graphic Designer</h3>
			<p class="text-[#555] leading-relaxed text-[0.95rem]">Created websites for small businesses and individuals, enhancing my skills in web design and development. Managed client relationships and delivered projects on time.</p>
		</div>
	</div>
</section>

<style>
	.gradient-text {
		-webkit-text-fill-color: var(--primary);
		color: var(--primary);
	}

	.experience-box:hover .experience-icon {
		transform: scale(1.1) rotate(8deg);
		border-radius: 50%;
	}
</style>
