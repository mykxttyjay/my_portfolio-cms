---
---

<section class="experience" id="experience">
	<h2 class="heading">Experience / <span>OJT</span></h2>
	<div class="experience-container">
		<div class="experience-box">
			<div class="experience-icon">
				<i class="fa-solid fa-briefcase"></i>
			</div>
			<h3>Web Development Internship</h3>
			<p>Assisted in developing web applications and gained hands-on experience in software development. Worked with modern frameworks and collaborated with senior developers.</p>
		</div>
		<div class="experience-box">
			<div class="experience-icon">
				<i class="fa-solid fa-laptop-code"></i>
			</div>
			<h3>Freelance Graphic Designer</h3>
			<p>Created websites for small businesses and individuals, enhancing my skills in web design and development. Managed client relationships and delivered projects on time.</p>
		</div>
	</div>
</section>

<style>
	.experience {
		background: var(--light);
		padding: 5rem 0;
	}

	.experience-container {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2.5rem;
		max-width: 1000px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.experience-box {
		background: var(--white);
		padding: 2.5rem 2rem;
		border-radius: 24px;
		box-shadow: 0 10px 30px rgba(162, 136, 166, 0.06);
		border: 1px solid rgba(162, 136, 166, 0.05);
		transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.experience-box:hover {
		transform: translateY(-8px);
		box-shadow: 0 20px 40px rgba(162, 136, 166, 0.12);
		border-color: rgba(162, 136, 166, 0.15);
	}

	.experience-icon {
		width: 60px;
		height: 60px;
		background: var(--gradient);
		border-radius: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--white);
		font-size: 1.5rem;
		margin-bottom: 1.5rem;
		box-shadow: 0 8px 20px rgba(162, 136, 166, 0.2);
		transition: transform 0.3s ease, border-radius 0.3s ease;
	}

	.experience-box:hover .experience-icon {
		transform: scale(1.1) rotate(8deg);
		border-radius: 50%;
	}

	.experience-box h3 {
		font-size: 1.4rem;
		color: var(--dark);
		margin-bottom: 1rem;
		font-weight: 700;
	}

	.experience-box p {
		color: #555;
		line-height: 1.7;
		font-size: 0.95rem;
	}
</style>
