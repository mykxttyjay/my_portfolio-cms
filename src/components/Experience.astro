---
---

<section class="experience" id="experience">
	<h2 class="heading">My <span>Experience</span></h2>
	<div class="experience-container">
		<div class="experience-box">
			<div class="experience-icon">
				<i class="fa-solid fa-briefcase"></i>
			</div>
			<h3>Web Development Internship</h3>
			<p>Assisted in developing web applications and gained hands-on experience in software development. Worked with modern frameworks and collaborated with senior developers.</p>
		</div>
		<div class="experience-box">
			<div class="experience-icon">
				<i class="fa-solid fa-laptop-code"></i>
			</div>
			<h3>Freelance Graphic Designer</h3>
			<p>Created websites for small businesses and individuals, enhancing my skills in web design and development. Managed client relationships and delivered projects on time.</p>
		</div>
	</div>
</section>

<style>
	.experience {
		background: var(--white);
	}

	.experience-container {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
		max-width: 1000px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.experience-box {
		background: var(--light);
		padding: 2rem;
		border-radius: 15px;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
		transition: transform 0.3s ease;
	}

	.experience-box:hover {
		transform: translateY(-10px);
	}

	.experience-icon {
		width: 60px;
		height: 60px;
		background: var(--gradient);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--white);
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	.experience-box h3 {
		font-size: 1.3rem;
		color: var(--dark);
		margin-bottom: 1rem;
	}

	.experience-box p {
		color: #666;
		line-height: 1.6;
	}
</style>
