---
import { getSkills } from '../lib/emdash';

const skillsData = getSkills();

// Flatten all skills into individual cards with icons
const skillIcons: Record<string, string> = {
	'Web Development': 'fa-solid fa-code',
	'Web Design': 'fa-solid fa-paintbrush',
	'UI/UX Design': 'fa-solid fa-pen-nib',
	'Graphic Design': 'fa-solid fa-palette',
	'Quality Assurance': 'fa-solid fa-check-circle',
	'PHP': 'fa-brands fa-php',
	'Astro': 'fa-solid fa-rocket',
	'Tailwind CSS': 'fa-solid fa-wind',
	'Java': 'fa-brands fa-java'
};

// Get Core Skills and Tools separately
const coreSkillsData = skillsData.find(s => s.category === 'Core Skills');
const toolsData = skillsData.find(s => s.category === 'Tools');

const skills = coreSkillsData?.skills_list ? coreSkillsData.skills_list.split(',').map((s: string) => ({
	name: s.trim(),
	icon: skillIcons[s.trim()] || 'fa-solid fa-code'
})) : [];

const tools = toolsData?.skills_list ? toolsData.skills_list.split(',').map((s: string) => ({
	name: s.trim(),
	icon: skillIcons[s.trim()] || 'fa-solid fa-code'
})) : [];
---

<section class="skills" id="skills">
	<div class="skills-content">
		<div class="skills-header">
			<h2 class="heading"><span>Skills</span></h2>
			<p class="skills-description">
				My expertise spans across web development, design, and quality assurance. 
				I specialize in creating user-centered digital experiences through thoughtful 
				design and reliable development. Each project is an opportunity to blend creativity 
				with technical precision, delivering solutions that are both functional and visually compelling.
			</p>
		</div>
		<div class="skills-right">
			<div class="skills-container">
				{tools.map((tool: any) => (
					<div class="skill-stamp">
						<div class="stamp-icon">
							<i class={tool.icon}></i>
						</div>
						<div class="stamp-content">
							{tool.name}
						</div>
					</div>
				))}
			</div>
			<div class="skills-list">
				{skills.map((skill: any) => (
					<div class="skill-line">{skill.name}</div>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.skills {
		background: #F5F0E8;
		padding: 3rem 0 5rem 0;
		position: relative;
		overflow: hidden;
		border: 20px solid transparent;
		border-image: repeating-linear-gradient(
			45deg,
			#2C3E50 0px,
			#2C3E50 15px,
			#C0392B 15px,
			#C0392B 30px,
			#F5F0E8 30px,
			#F5F0E8 45px
		) 20;
	}

	.skills::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			url("data:image/svg+xml,%3Csvg viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' result='noise' seed='2' /%3E%3CfeColorMatrix in='noise' type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100' height='100' fill='%23000000' filter='url(%23noiseFilter)' opacity='0.15'/%3E%3C/svg%3E");
		background-size: 100px 100px;
		pointer-events: none;
		z-index: 0;
		mix-blend-mode: overlay;
	}

	.skills-content {
		display: flex;
		align-items: flex-start;
		gap: 3rem;
		margin-left: 96px;
		padding: 0 2rem 0 0;
		position: relative;
	}

	.skills-content::after {
		content: '';
		position: absolute;
		left: 40%;
		top: 0;
		bottom: 0;
		width: 2px;
		background: linear-gradient(
			to bottom,
			transparent 0%,
			#4A1215 10%,
			#4A1215 90%,
			transparent 100%
		);
		opacity: 0.3;
		transform: translateX(-50%);
	}

	.skills-header {
		margin: 0;
		padding: 0 3rem 0 0;
		text-align: left;
		position: relative;
		z-index: 1;
		flex-shrink: 0;
		width: 40%;
	}

	.skills-right {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		flex: 1;
		width: 60%;
		padding-left: 3rem;
		position: relative;
		z-index: 1;
	}

	.skills-list {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		width: 100%;
	}

	.skill-line {
		font-family: 'Playfair Display', Georgia, serif;
		font-size: 23px;
		color: #4A1215;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid rgba(74, 18, 21, 0.3);
		font-style: italic;
		width: 100%;
		font-weight: 700;
	}

	.skills .heading {
		color: #4A1215;
		position: relative;
		z-index: 1;
		font-family: 'Playfair Display', Georgia, serif;
		font-size: 3.5rem;
		font-weight: 700;
		letter-spacing: 1px;
		font-style: italic;
		text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
		text-align: left;
		margin-bottom: 0.5rem;
	}

	.skills .heading span {
		-webkit-text-fill-color: #4A1215;
		color: #4A1215;
	}

	.skills-description {
		color: #4A1215;
		font-size: 20px;
		line-height: 1.6;
		font-family: 'Playfair Display', Georgia, serif;
		opacity: 0.85;
		margin-bottom: calc(20px * 1.6 * 5);
		position: relative;
	}

	.skills-description::after {
		content: '';
		position: absolute;
		bottom: calc(-20px * 1.6 * 5);
		left: 0;
		width: 100%;
		height: calc(20px * 1.6 * 4);
		background: 
			linear-gradient(to right, #4A1215 0%, #4A1215 100%) 0 calc(20px * 1.1) / 100% 1px no-repeat,
			linear-gradient(to right, #4A1215 0%, #4A1215 100%) 0 calc(20px * 1.1 + 20px * 1.6) / 100% 1px no-repeat,
			linear-gradient(to right, #4A1215 0%, #4A1215 100%) 0 calc(20px * 1.1 + 20px * 1.6 * 2) / 100% 1px no-repeat,
			linear-gradient(to right, #4A1215 0%, #4A1215 100%) 0 calc(20px * 1.1 + 20px * 1.6 * 3) / 100% 1px no-repeat;
		opacity: 0.3;
	}

	.skills-container {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
		position: relative;
		z-index: 1;
		justify-content: end;
		margin-left: auto;
		width: fit-content;
	}

	.skill-stamp {
		background: #FCF8F2;
		border: none;
		padding: 0.8rem;
		border-radius: 0;
		box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1), -2px 2px 6px rgba(0, 0, 0, 0.08);
		transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: visible;
		aspect-ratio: 1/1;
		transform: rotate(0deg);
		width: 112px;
		height: 112px;
		margin-bottom: 1rem;
	}

	.skill-stamp::before {
		content: '';
		position: absolute;
		inset: -8px;
		background: #FFFEF8;
		z-index: -1;
		clip-path: polygon(
			/* Top edge - wavy */
			0% 4px, 4px 0%, 8px 4px, 12px 0%, 16px 4px, 20px 0%, 24px 4px, 28px 0%, 32px 4px, 36px 0%, 40px 4px, 44px 0%, 48px 4px, 52px 0%, 56px 4px, 60px 0%, 64px 4px, 68px 0%, 72px 4px, 76px 0%, 80px 4px, 84px 0%, 88px 4px, 92px 0%, 96px 4px, 100px 0%, 104px 4px, 108px 0%, 112px 4px, 116px 0%, 120px 4px, 124px 0%, 128px 4px,
			/* Top-right corner - wavy transition */
			calc(100% - 4px) 0%, 100% 0%, 100% 4px,
			/* Right edge - wavy */
			calc(100% - 4px) 8px, 100% 12px, calc(100% - 4px) 16px, 100% 20px, calc(100% - 4px) 24px, 100% 28px, calc(100% - 4px) 32px, 100% 36px, calc(100% - 4px) 40px, 100% 44px, calc(100% - 4px) 48px, 100% 52px, calc(100% - 4px) 56px, 100% 60px, calc(100% - 4px) 64px, 100% 68px, calc(100% - 4px) 72px, 100% 76px, calc(100% - 4px) 80px, 100% 84px, calc(100% - 4px) 88px, 100% 92px, calc(100% - 4px) 96px, 100% 100px, calc(100% - 4px) 104px, 100% 108px, calc(100% - 4px) 112px, 100% 116px, calc(100% - 4px) 120px, 100% 124px, calc(100% - 4px) 128px,
			/* Bottom-right corner - wavy transition */
			100% calc(100% - 4px), 100% 100%, calc(100% - 4px) 100%,
			/* Bottom edge - wavy */
			calc(100% - 8px) calc(100% - 4px), calc(100% - 12px) 100%, calc(100% - 16px) calc(100% - 4px), calc(100% - 20px) 100%, calc(100% - 24px) calc(100% - 4px), calc(100% - 28px) 100%, calc(100% - 32px) calc(100% - 4px), calc(100% - 36px) 100%, calc(100% - 40px) calc(100% - 4px), calc(100% - 44px) 100%, calc(100% - 48px) calc(100% - 4px), calc(100% - 52px) 100%, calc(100% - 56px) calc(100% - 4px), calc(100% - 60px) 100%, calc(100% - 64px) calc(100% - 4px), calc(100% - 68px) 100%, calc(100% - 72px) calc(100% - 4px), calc(100% - 76px) 100%, calc(100% - 80px) calc(100% - 4px), calc(100% - 84px) 100%, calc(100% - 88px) calc(100% - 4px), calc(100% - 92px) 100%, calc(100% - 96px) calc(100% - 4px), calc(100% - 100px) 100%, calc(100% - 104px) calc(100% - 4px), calc(100% - 108px) 100%, calc(100% - 112px) calc(100% - 4px), calc(100% - 116px) 100%, calc(100% - 120px) calc(100% - 4px), calc(100% - 124px) 100%, calc(100% - 128px) calc(100% - 4px),
			/* Bottom-left corner - wavy transition */
			4px 100%, 0% 100%, 0% calc(100% - 4px),
			/* Left edge - wavy */
			4px calc(100% - 8px), 0% calc(100% - 12px), 4px calc(100% - 16px), 0% calc(100% - 20px), 4px calc(100% - 24px), 0% calc(100% - 28px), 4px calc(100% - 32px), 0% calc(100% - 36px), 4px calc(100% - 40px), 0% calc(100% - 44px), 4px calc(100% - 48px), 0% calc(100% - 52px), 4px calc(100% - 56px), 0% calc(100% - 60px), 4px calc(100% - 64px), 0% calc(100% - 68px), 4px calc(100% - 72px), 0% calc(100% - 76px), 4px calc(100% - 80px), 0% calc(100% - 84px), 4px calc(100% - 88px), 0% calc(100% - 92px), 4px calc(100% - 96px), 0% calc(100% - 100px), 4px calc(100% - 104px), 0% calc(100% - 108px), 4px calc(100% - 112px), 0% calc(100% - 116px), 4px calc(100% - 120px), 0% calc(100% - 124px), 4px calc(100% - 128px),
			/* Top-left corner - wavy transition */
			0% 4px, 0% 0%
		);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
	}

	.skill-stamp:nth-child(2n) {
		transform: rotate(0deg);
	}

	.skill-stamp:nth-child(3n) {
		transform: rotate(0deg);
	}

	.skill-stamp:nth-child(4n) {
		transform: rotate(0deg);
	}

	.skill-stamp:nth-child(5n) {
		transform: rotate(0deg);
	}

	.skill-stamp:hover {
		transform: rotate(0deg) translateY(-8px) scale(1.05);
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.18), -6px 6px 15px rgba(0, 0, 0, 0.12);
	}

	.stamp-icon {
		width: 28px;
		height: 28px;
		background: #f5f0f0;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #A31D1D;
		font-size: 0.9rem;
		margin-bottom: 0.4rem;
		box-shadow: 0 3px 8px rgba(163, 29, 29, 0.1);
		border: 2px solid rgba(163, 29, 29, 0.2);
		transition: all 0.3s ease;
		position: relative;
		z-index: 2;
	}

	.skill-stamp:hover .stamp-icon {
		transform: scale(1.15) rotate(10deg);
		background: linear-gradient(135deg, #A31D1D 0%, #8B1515 100%);
		color: #FEF9E1;
		border-color: transparent;
	}

	.stamp-content {
		font-size: 11px;
		font-weight: 700;
		color: #4A1215;
		letter-spacing: 0.2px;
		font-family: 'Playfair Display', Georgia, serif;
		text-transform: uppercase;
		line-height: 1.2;
		position: relative;
		z-index: 2;
	}

	@media (max-width: 1024px) {
		.skills-content {
			flex-direction: column;
		}

		.skills-content::after {
			display: none;
		}

		.skills-header {
			width: 100%;
			margin: 0 0 2rem 0;
			padding: 0;
		}

		.skills-container {
			width: 100%;
			padding-left: 0;
			grid-template-columns: repeat(3, 1fr);
			gap: 1.2rem;
		}
	}

	@media (max-width: 768px) {
		.skills-container {
			grid-template-columns: repeat(3, 1fr);
			gap: 1rem;
		}
	}

	@media (max-width: 480px) {
		.skills-container {
			grid-template-columns: repeat(2, 1fr);
			gap: 0.8rem;
		}
		
		.skill-stamp {
			padding: 1rem 0.5rem;
		}
		
		.stamp-icon {
			width: 40px;
			height: 40px;
			font-size: 1.1rem;
		}
		
		.stamp-content {
			font-size: 0.8rem;
		}
	}
</style>
