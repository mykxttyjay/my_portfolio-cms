---

<header class="header">
	<nav class="nav">
		<a href="#home">Graphic Design</a>
		<a href="#education">Web Development</a>
		<a href="#skills">UI Design</a>
	</nav>

	<div class="header-divider">
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 100" preserveAspectRatio="none">
			<path d="M0,50 Q80,0 160,50 T320,50 T480,50 T640,50 T800,50 T960,50 T1120,50 T1280,50 T1440,50 L1440,100 L0,100 Z" fill="#ecdddf"/>
		</svg>
	</div>
</header>

<style>
	.header {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		padding: 2rem 8%;
		background-color: #a288a6;
		position: sticky;
		top: 0;
		z-index: 50;
	}

	.nav {
		display: flex;
		gap: 2rem;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
	}

	.nav a {
		text-decoration: none;
		color: #ffffff;
		font-weight: 600;
		font-size: 1.1rem;
		transition: color 0.3s ease;
	}

	.nav a:hover {
		color: #ecdddf;
	}

	.heart {
		color: #ffffff;
		font-size: 1.2rem;
	}

	.header-divider {
		width: 100%;
		line-height: 0;
		margin: 0;
		padding: 0;
		margin-top: 1rem;
	}

	.header-divider svg {
		display: block;
		width: 100%;
		height: 50px;
	}
</style>
