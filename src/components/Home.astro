---
import CloudIcon from '../assets/cloud.svg';
---

<section class="home" id="home">
	<div class="home-container">
		<div class="year">2024</div>
		<h1 class="portfolio-title">PORTFOLIO</h1>
		
		<div class="illustration-placeholder">
			<div class="character-box">
				<p>Your Illustration Here</p>
			</div>
		</div>
		
		<p class="welcome-text">WELCOME</p>
	</div>

	<div class="clouds">
		<CloudIcon class="cloud-style cloud-1" />
		<CloudIcon class="cloud-style cloud-2" />
		<CloudIcon class="cloud-style cloud-3" />
	</div>
</section>

<style>
	.home {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 5rem 8%;
		position: relative;
		background-color: #ecdddf;
		overflow: hidden;
	}

	.home-container {
		text-align: center;
		z-index: 1;
		width: 100%;
	}

	.year {
		font-size: 1.2rem;
		color: var(--primary);
		font-weight: 600;
		margin-bottom: 1rem;
		letter-spacing: 2px;
	}

	.portfolio-title {
		font-size: 5rem;
		font-weight: 700;
		color: var(--secondary);
		margin-bottom: 2rem;
		letter-spacing: 8px;
		text-shadow: 0 4px 15px rgba(162, 136, 166, 0.2);
	}

	.illustration-placeholder {
		display: flex;
		justify-content: center;
		align-items: center;
		margin: 3rem 0;
		min-height: 300px;
	}

	.character-box {
		width: 400px;
		height: 300px;
		background: linear-gradient(135deg, rgba(187, 155, 176, 0.3) 0%, rgba(204, 188, 188, 0.2) 100%);
		border-radius: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 2px dashed var(--secondary);
		color: var(--primary);
		font-size: 1.2rem;
		font-weight: 600;
	}

	.welcome-text {
		font-size: 1.5rem;
		color: var(--secondary);
		font-weight: 600;
		letter-spacing: 3px;
		margin-top: 2rem;
	}

	.clouds {
		position: absolute;
		bottom: -80px;
		left: 0;
		right: 0;
		height: 120px;
		z-index: 1;
		pointer-events: none;
		width: 100%;
		overflow: hidden;
	}

	.cloud-style {
		position: absolute;
		bottom: 0;
		width: 100px;
		height: auto;
		fill: white;
		opacity: 0.7;
	}

	.cloud-1 {
		left: 5%;
		animation: moveClouds 60s linear infinite;
	}

	.cloud-2 {
		left: 35%;
		animation: moveClouds 80s linear infinite reverse;
		width: 120px;
	}

	.cloud-3 {
		left: 65%;
		animation: moveClouds 100s linear infinite;
		width: 90px;
	}

	@keyframes moveClouds {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(100vw);
		}
	}

	@media (max-width: 768px) {
		.home {
			padding: 3rem 5%;
		}

		.portfolio-title {
			font-size: 3rem;
			letter-spacing: 4px;
		}

		.character-box {
			width: 300px;
			height: 200px;
		}

		.welcome-text {
			font-size: 1.2rem;
		}
	}
</style>
