---
import { profile } from '../data/portfolio';

const name = profile?.name?.split(' ')[0] || "Angel";
const role = profile?.role || "A Designer & Developer";
const intro = profile?.intro || "Welcome to my portfolio! I'm excited to share my journey, projects, and passion for technology with you. Let's explore what we can build together.";
---

<section class="home" id="home">
	<!-- Background Crumpled Texture & Vignette Overlay -->
	<div class="crumpled-overlay"></div>

	<!-- Minimal floating sparkling diamonds -->
	<div class="sparkles-container">
		<div class="sparkle sparkle-1">
			<svg viewBox="0 0 24 24"><path d="M12,2 L15,9 L22,12 L15,15 L12,22 L9,15 L2,12 L9,9 Z" /></svg>
		</div>
		<div class="sparkle sparkle-2">
			<svg viewBox="0 0 24 24"><path d="M12,2 L14,10 L22,12 L14,14 L12,22 L10,14 L2,12 L10,10 Z" /></svg>
		</div>
		<div class="sparkle sparkle-3">
			<svg viewBox="0 0 24 24"><path d="M12,2 L15,9 L22,12 L15,15 L12,22 L9,15 L2,12 L9,9 Z" /></svg>
		</div>
		<div class="sparkle sparkle-4">
			<svg viewBox="0 0 24 24"><path d="M12,2 L14,10 L22,12 L14,14 L12,22 L10,14 L2,12 L10,10 Z" /></svg>
		</div>
		<div class="sparkle sparkle-5">
			<svg viewBox="0 0 24 24"><path d="M12,2 L15,9 L22,12 L15,15 L12,22 L9,15 L2,12 L9,9 Z" /></svg>
		</div>
		<div class="sparkle sparkle-6">
			<svg viewBox="0 0 24 24"><path d="M12,2 L14,10 L22,12 L14,14 L12,22 L10,14 L2,12 L10,10 Z" /></svg>
		</div>
	</div>

	<!-- Centered envelope with letter inside -->
	<div class="envelope-container">
		
		<!-- 1. Envelope Back Flap (behind the letter) -->
		<div class="envelope-back">
			<svg viewBox="0 0 650 400" preserveAspectRatio="none">
				<!-- Triangular open flap pointing up, slightly darker cream for depth shadow -->
				<path d="M 5,395 L 5,180 L 325,5 L 645,180 L 645,395 Z" fill="#EADFCB" stroke="#4A1215" stroke-width="4.5" stroke-linejoin="round" />
			</svg>
		</div>

		<!-- 2. Letter paper wrapper (clips bottom) -->
		<div class="letter-wrapper">
			<div class="letter-paper">
			<!-- Notebook Perforated Top Edge -->
			<div class="notebook-top">
				<svg class="notebook-tear-svg" viewBox="0 0 600 35" preserveAspectRatio="none">
					<!-- Punched spiral binding holes (filled with background red to look cut-out) -->
					<g fill="#8F1D21" stroke="#4A1215" stroke-width="2.5">
						<circle cx="30" cy="12" r="6" />
						<circle cx="60" cy="12" r="6" />
						<circle cx="90" cy="12" r="6" />
						<circle cx="120" cy="12" r="6" />
						<circle cx="150" cy="12" r="6" />
						<circle cx="180" cy="12" r="6" />
						<circle cx="210" cy="12" r="6" />
						<circle cx="240" cy="12" r="6" />
						<circle cx="270" cy="12" r="6" />
						<circle cx="300" cy="12" r="6" />
						<circle cx="330" cy="12" r="6" />
						<circle cx="360" cy="12" r="6" />
						<circle cx="390" cy="12" r="6" />
						<circle cx="420" cy="12" r="6" />
						<circle cx="450" cy="12" r="6" />
						<circle cx="480" cy="12" r="6" />
						<circle cx="510" cy="12" r="6" />
						<circle cx="540" cy="12" r="6" />
						<circle cx="570" cy="12" r="6" />
					</g>
					<!-- Dotted tear line below holes -->
					<line x1="15" y1="28" x2="585" y2="28" stroke="#4A1215" stroke-width="2.5" stroke-dasharray="5,6" stroke-linecap="round" />
				</svg>
			</div>

			<!-- Letter Contents -->
			<div class="letter-content">
				<h1 class="letter-title">Hello, I'm {name}</h1>
				<div class="letter-role-capsule">{role}</div>
				<p class="letter-description">{intro}</p>
			</div>
			</div>
		</div>

		<!-- 3. Envelope Front Body pocket (Covers bottom of letter) -->
		<div class="envelope-body">
			<svg class="envelope-front-svg" viewBox="0 0 650 220" preserveAspectRatio="none">
				<!-- Outer pocket fold (covers the letter bottom) -->
				<path d="M 5,215 L 5,5 L 325,120 L 645,5 L 645,215 Z" fill="#FCF8F2" stroke="#4A1215" stroke-width="4.5" stroke-linejoin="round" />
				<!-- Crease lines meeting in the center seal -->
				<path d="M 5,215 L 325,120" stroke="#4A1215" stroke-width="4" stroke-linecap="round" />
				<path d="M 645,215 L 325,120" stroke="#4A1215" stroke-width="4" stroke-linecap="round" />
			</svg>
			
			<!-- 4. Wax Seal in the center of folds (Mathematically locked to intersection) -->
			<div class="wax-seal">
				<svg viewBox="0 0 120 120" class="wax-seal-svg">
					<!-- Melted organic outer wax circle -->
					<path d="M 60,6 C 92,3 116,21 114,56 C 112,88 95,116 63,114 C 29,112 4,93 6,57 C 8,23 28,9 60,6 Z" fill="#8F1D21" stroke="#4A1215" stroke-width="4.5" stroke-linejoin="round" />
					<!-- Stamped inner ridge -->
					<circle cx="60" cy="60" r="41" fill="#A12227" stroke="#4A1215" stroke-width="3" />
					<!-- Glossy reflection -->
					<path d="M 33,33 A 28,28 0 0 1 87,33" fill="none" stroke="rgba(255, 255, 255, 0.2)" stroke-width="4.5" stroke-linecap="round" />
					<!-- Embossed Star in center -->
					<polygon points="60,36 66,50 81,50 69,60 74,75 60,66 46,75 51,60 39,50 54,50" fill="#5A0E11" stroke="#4A1215" stroke-width="3" stroke-linejoin="round" />
				</svg>
			</div>
		</div>
	</div>

	</div>
</section>

<script>
	const initScrollConnect = () => {
		const homeSection = document.querySelector('.home');
		const aboutSection = document.querySelector('.about');
		const letterPaper = document.querySelector('.letter-paper');
		const combinedCard = document.querySelector('.combined-about-card');
		
		if (!homeSection || !aboutSection || !letterPaper || !combinedCard) return;

		// Enable scroll transition after initial animation completes
		setTimeout(() => {
			letterPaper.classList.add('scroll-transition');
		}, 6000);

		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.target === aboutSection) {
					if (entry.isIntersecting) {
						// About section visible - letter goes back, card comes out
						homeSection.classList.add('scroll-connect');
						aboutSection.classList.add('scroll-connect');
						letterPaper.classList.add('letter-hidden');
						combinedCard.classList.add('scroll-active');
					} else {
						// About section not visible - letter comes out, card goes back
						homeSection.classList.remove('scroll-connect');
						aboutSection.classList.remove('scroll-connect');
						letterPaper.classList.remove('letter-hidden');
						combinedCard.classList.remove('scroll-active');
					}
				}
			});
		}, { threshold: 0.2 });

		observer.observe(aboutSection);
	};

	initScrollConnect();
	document.addEventListener('astro:page-load', initScrollConnect);
</script>

<style>
	.home {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 6rem 2rem 4rem;
		position: relative;
		background-color: #8F1D21; /* Matches dark red binding holes background */
		overflow: hidden;
	}

	.home.scroll-connect {
		animation: home-connect 0.6s ease-out forwards;
	}

	@keyframes home-connect {
		from {
			opacity: 1;
		}
		to {
			opacity: 1;
		}
	}

	/* Crumpled paper noise + gradient overlay */
	.home::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			url("data:image/svg+xml,%3Csvg viewBox='0 0 150 150' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.03' numOctaves='4' result='noise' seed='1' /%3E%3CfeColorMatrix in='noise' type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' fill='%23000000' filter='url(%23noiseFilter)' opacity='0.12'/%3E%3C/svg%3E");
		background-size: 150px 150px;
		pointer-events: none;
		z-index: 2;
		mix-blend-mode: overlay;
	}

	.crumpled-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: radial-gradient(circle at 50% 50%, rgba(155, 30, 34, 0.4) 0%, rgba(90, 14, 17, 0.85) 100%);
		pointer-events: none;
		z-index: 1;
	}

	.envelope-top-flap {
		position: absolute;
		top: 45%; 
		left: 0;
		width: 100%;
		height: 45%; 
		z-index: 20;
		transform-origin: top center;
		transform-style: preserve-3d;
		animation: open-flap 1.2s cubic-bezier(0.4, 0, 0.2, 1) 3s forwards, push-back 0.1s linear 4.2s forwards;
	}

	@keyframes open-flap {
		0% { transform: rotateX(0deg); }
		100% { transform: rotateX(180deg); }
	}

	@keyframes push-back {
		to { z-index: 5; }
	}

	.flap-outside, .flap-inside {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		backface-visibility: hidden;
	}

	.flap-inside {
		transform: rotateX(180deg);
	}

	.flap-outside svg, .flap-inside svg {
		width: 100%;
		height: 100%;
	}
	
	.flap-outside {
		filter: drop-shadow(0 6px 12px rgba(0, 0, 0, 0.15));
	}

	.envelope-container {
		width: 1100px;
		max-width: 95%;
		aspect-ratio: 650 / 400;
		position: relative;
		z-index: 10;
		margin: 0 auto;
	}

	.envelope-back {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 8;
	}

	.envelope-back svg {
		width: 100%;
		height: 100%;
		filter: drop-shadow(0 6px 12px rgba(0, 0, 0, 0.15));
	}

	.letter-wrapper {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 10;
		clip-path: inset(-200% -20% 4% -20%);
	}

	.letter-paper {
		background: #FCF8F2;
		border: 3.5px solid #4A1215;
		border-bottom: none;
		padding: 2.5rem 1.8rem 2rem;
		text-align: center;
		box-shadow: 0 -8px 20px rgba(0, 0, 0, 0.15);
		position: absolute;
		border-radius: 16px 16px 0 0;
		width: 92%;
		left: 4%;
		height: 100.5%;
		top: 60%;
		transform: translateY(0);
		animation: slide-up-letter 2.5s forwards;
		animation-delay: 4.2s;
	}

	@keyframes slide-up-letter {
		0% {
			top: 60%;
			animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
		}
		35% {
			top: 15%;
			animation-timing-function: linear;
		}
		65% {
			top: 15%;
			animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
		}
		100% {
			top: -5%;
		}
	}

	.letter-paper.scroll-transition {
		transition: top 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
		animation: none;
	}

	.home.scroll-connect .letter-paper.scroll-transition {
		top: 60%;
	}

	.letter-paper.scroll-transition:not(.letter-hidden) {
		top: -5%;
	}

	.notebook-top {
		width: 100%;
		margin-bottom: 0.8rem;
		margin-top: -0.2rem;
	}

	.notebook-tear-svg {
		width: 100%;
		height: 28px;
	}

	.letter-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		height: auto;
		padding-top: 0.2rem;
	}

	.letter-title {
		font-size: 5rem;
		font-weight: 900;
		color: #4A1215;
		margin-bottom: 2rem;
		font-family: 'Playfair Display', Georgia, serif;
		letter-spacing: -1px;
		line-height: 1.05;
		text-shadow: 0 2px 8px rgba(74, 18, 21, 0.08);
	}

	.letter-role-capsule {
		font-size: 1.5rem;
		color: #FCF8F2;
		background-color: #631B20;
		font-weight: 700;
		font-style: italic;
		margin-bottom: 2.8rem;
		padding: 0.6rem 2.5rem;
		border: 2.5px solid #4A1215;
		border-radius: 50px;
		display: inline-block;
		font-family: 'Playfair Display', Georgia, serif;
		box-shadow: 0 6px 16px rgba(74, 18, 21, 0.25);
		letter-spacing: 0.3px;
	}

	.letter-description {
		font-size: 1.5rem;
		line-height: 1.6;
		color: #4A1215;
		max-width: 920px;
		margin: -0.5rem auto 0;
		font-family: 'Playfair Display', Georgia, serif;
		font-weight: 500;
		letter-spacing: 0.1px;
	}

	.envelope-body {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 55%;
		z-index: 15;
		filter: drop-shadow(0 10px 25px rgba(0, 0, 0, 0.3));
	}

	.envelope-front-svg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
	}

	.wax-seal {
		width: 140px;
		height: 140px;
		position: absolute;
		top: 54.5%;
		left: 50%;
		transform: translate(-50%, -50%);
		filter: drop-shadow(0 6px 12px rgba(0, 0, 0, 0.35));
		opacity: 1;
		z-index: 25;
	}

	.wax-seal-svg {
		width: 100%;
		height: 100%;
	}

	/* Responsive Text and Proportions Sizes */
	@media (max-width: 768px) {
		.home {
			padding: 4rem 1.5rem 3rem;
		}

		.letter-title {
			font-size: 1.8rem;
		}

		.letter-role-capsule {
			font-size: 0.85rem;
			padding: 0.25rem 1.1rem;
		}

		.letter-description {
			font-size: 0.85rem;
			max-width: 340px;
		}

		.letter-paper {
			padding: 1rem 1.5rem 0.8rem;
		}

		.wax-seal {
			width: 80px;
			height: 80px;
		}
	}

	@media (max-width: 480px) {
		.home {
			padding: 3rem 1rem 2rem;
		}

		.letter-title {
			font-size: 1.35rem;
			margin-bottom: 0.2rem;
		}

		.letter-role-capsule {
			font-size: 0.75rem;
			padding: 0.2rem 0.8rem;
			margin-bottom: 0.4rem;
			border-width: 1.5px;
		}

		.letter-description {
			font-size: 0.7rem;
			line-height: 1.4;
			max-width: 240px;
		}

		.letter-paper {
			padding: 0.8rem 1rem 0.5rem;
			border-width: 2.5px;
		}

		.notebook-tear-svg {
			height: 18px;
		}

		.wax-seal {
			width: 65px;
			height: 65px;
		}
	}

	/* Minimal Floating Sparkling Diamonds */
	.sparkles-container {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 12;
		overflow: hidden;
	}

	.sparkle {
		position: absolute;
		opacity: 0;
		color: #FFF2D4; /* Champagne gold */
		filter: drop-shadow(0 0 8px rgba(255, 242, 212, 0.8));
		pointer-events: none;
		transform-origin: center;
		/* Sync fade-in with the letter rising up (4.2s delay) */
		animation: sparkle-fade-in 1.5s cubic-bezier(0.25, 1, 0.5, 1) 4.2s forwards;
	}

	@keyframes sparkle-fade-in {
		0% {
			opacity: 0;
		}
		100% {
			opacity: 0.85;
		}
	}

	.sparkle svg {
		width: 100%;
		height: 100%;
		fill: currentColor;
		display: block;
		transform-origin: center;
	}

	.sparkle-1 {
		top: 15%;
		left: 10%;
		width: 28px;
		height: 28px;
	}
	.sparkle-1 svg {
		animation: twinkle-1 4s ease-in-out 4.2s infinite;
	}

	.sparkle-2 {
		top: 25%;
		right: 12%;
		width: 22px;
		height: 22px;
	}
	.sparkle-2 svg {
		animation: twinkle-2 3.5s ease-in-out 4.2s infinite;
	}

	.sparkle-3 {
		top: 45%;
		left: 14%;
		width: 18px;
		height: 18px;
	}
	.sparkle-3 svg {
		animation: twinkle-3 5s ease-in-out 4.2s infinite;
	}

	.sparkle-4 {
		top: 55%;
		right: 8%;
		width: 32px;
		height: 32px;
	}
	.sparkle-4 svg {
		animation: twinkle-4 4.5s ease-in-out 4.2s infinite;
	}

	.sparkle-5 {
		top: 70%;
		left: 8%;
		width: 24px;
		height: 24px;
	}
	.sparkle-5 svg {
		animation: twinkle-1 3.8s ease-in-out 4.2s infinite;
	}

	.sparkle-6 {
		top: 75%;
		right: 15%;
		width: 20px;
		height: 20px;
	}
	.sparkle-6 svg {
		animation: twinkle-2 4.2s ease-in-out 4.2s infinite;
	}

	@keyframes twinkle-1 {
		0%, 100% {
			transform: scale(0.6) translateY(0) rotate(0deg);
			opacity: 0.4;
		}
		50% {
			transform: scale(1.1) translateY(-15px) rotate(180deg);
			opacity: 1;
		}
	}

	@keyframes twinkle-2 {
		0%, 100% {
			transform: scale(0.8) translateY(0) rotate(0deg);
			opacity: 0.5;
		}
		50% {
			transform: scale(1.2) translateY(-25px) rotate(-90deg);
			opacity: 1;
		}
	}

	@keyframes twinkle-3 {
		0%, 100% {
			transform: scale(0.5) translateY(0) rotate(0deg);
			opacity: 0.3;
		}
		50% {
			transform: scale(1) translateY(-10px) rotate(120deg);
			opacity: 0.9;
		}
	}

	@keyframes twinkle-4 {
		0%, 100% {
			transform: scale(0.7) translateY(0) rotate(0deg);
			opacity: 0.5;
		}
		50% {
			transform: scale(1.3) translateY(-20px) rotate(45deg);
			opacity: 1;
		}
	}

	@media (max-width: 768px) {
		.sparkle-1 { left: 4%; top: 10%; width: 18px; height: 18px; }
		.sparkle-2 { right: 4%; top: 20%; width: 14px; height: 14px; }
		.sparkle-3 { left: 3%; top: 40%; width: 12px; height: 12px; }
		.sparkle-4 { right: 3%; top: 50%; width: 20px; height: 20px; }
		.sparkle-5 { left: 5%; top: 68%; width: 16px; height: 16px; }
		.sparkle-6 { right: 5%; top: 78%; width: 14px; height: 14px; }
	}
</style>
