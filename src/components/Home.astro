---
import CloudIcon from '../assets/cloud.svg';
import { getEmDashCollection } from 'emdash';

let name = "Angel Marie Sabido";
let role = "IT Student";
let intro = "Aspiring IT professional with a strong work ethic and a passion for learning and growth in the technology field. Committed to developing technical skills and contributing positively to team environments. Eager to gain hands-on experience and continuously improve to deliver quality results in any task or project.";
let aboutContent = "Driven by curiosity and a desire to make an impact, I aim to leverage my skills to support organizational goals, create innovative digital solutions, and grow as a well-rounded IT professional.";
let resumeLink = "https://linkedin.com/in/gelmarie";

try {
	const { entries } = await getEmDashCollection('profile');
	if (entries && entries.length > 0 && entries[0].data) {
		name = (entries[0].data.name as string) || name;
		role = (entries[0].data.role as string) || role;
		intro = (entries[0].data.intro as string) || intro;
		aboutContent = (entries[0].data.about_content as string) || aboutContent;
		resumeLink = (entries[0].data.resume_link as string) || resumeLink;
	}
} catch (e) {
	console.error('Error fetching profile from EmDash:', e);
}
---

<section class="home" id="home">
	<div class="home-img">
		<div class="rotating-border"></div>
		<div class="rotating-border-2"></div>
		<img src="main.jpg" alt={name} />
		<div class="img-glow"></div>
	</div>

	<div class="home-content">
		<h1 class="fade-in">Hi, I'm <span class="gradient-text">{name}</span></h1>
		<h3 class="typing-text fade-in-delay-1">I'm a <span></span></h3>
		<p class="fade-in-delay-2">{intro}</p>
		<br />
		<p class="fade-in-delay-2">{aboutContent}</p>
		<div class="btn-group fade-in-delay-3">
			<a href="#contact" class="btn">Contact Me</a>
			<a href="#projects" class="btn btn-secondary">View Projects</a>
			<a href={resumeLink} target="_blank" class="btn btn-secondary"><i class="fa-solid fa-download"></i> Download CV</a>
		</div>
		<div class="social-icons fade-in-delay-4">
			<a href="https://www.linkedin.com/in/gelmarie" target="_blank" title="LinkedIn"><i class="fa-brands fa-linkedin"></i></a>
			<a href="https://github.com/mykxttyjay" target="_blank" title="GitHub"><i class="fa-brands fa-github"></i></a>
			<a href="https://twitter.com/mykxttyjay" target="_blank" title="Twitter"><i class="fa-brands fa-x-twitter"></i></a>
			<a href="https://www.instagram.com/gelmarieee" target="_blank" title="Instagram"><i class="fa-brands fa-instagram"></i></a>
		</div>
	</div>

	<div class="clouds">
		<CloudIcon class="cloud-style cloud-1" />
		<CloudIcon class="cloud-style cloud-2" />
		<CloudIcon class="cloud-style cloud-3" />
	</div>
</section>

<style>
	.home {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 5rem 8%;
		gap: 2rem;
		position: relative;
		background-color: var(--light);
		overflow: hidden;
	}

	.home-img {
		position: relative;
		flex: 1;
		display: flex;
		justify-content: center;
		align-items: center;
		z-index: 1;
	}

	.home-img img {
		width: 300px;
		height: 300px;
		border-radius: 50%;
		object-fit: cover;
		position: relative;
		z-index: 2;
		box-shadow: 0 20px 60px rgba(162, 136, 166, 0.3), 0 0 40px rgba(187, 155, 176, 0.2);
		border: 3px solid rgba(255, 255, 255, 0.8);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.home-img img:hover {
		transform: scale(1.05);
		box-shadow: 0 25px 70px rgba(162, 136, 166, 0.4), 0 0 50px rgba(187, 155, 176, 0.3);
	}

	.rotating-border,
	.rotating-border-2 {
		position: absolute;
		border-radius: 50%;
		border: 2px solid transparent;
		border-top-color: var(--primary);
		border-right-color: var(--secondary);
		animation: rotate 3s linear infinite;
	}

	.rotating-border {
		width: 320px;
		height: 320px;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
	}

	.rotating-border-2 {
		width: 350px;
		height: 350px;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		animation: rotate 4s linear infinite reverse;
		border-top-color: var(--secondary);
		border-right-color: var(--accent);
	}

	@keyframes rotate {
		from {
			transform: translate(-50%, -50%) rotate(0deg);
		}
		to {
			transform: translate(-50%, -50%) rotate(360deg);
		}
	}

	.img-glow {
		position: absolute;
		width: 320px;
		height: 320px;
		background: radial-gradient(circle, rgba(162, 136, 166, 0.2) 0%, transparent 70%);
		border-radius: 50%;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		filter: blur(20px);
	}

	.home-content {
		flex: 1;
		padding-left: 1rem;
		z-index: 1;
		animation: slideInLeft 0.8s ease-out;
	}

	@keyframes slideInLeft {
		from {
			opacity: 0;
			transform: translateX(-50px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	.home-content h1 {
		font-size: 3.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		line-height: 1.2;
		color: var(--dark);
		text-shadow: 0 2px 10px rgba(162, 136, 166, 0.1);
	}

	.gradient-text {
		background: var(--gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-weight: 800;
	}

	.typing-text {
		font-size: 1.5rem;
		color: var(--primary);
		margin-bottom: 1.5rem;
		font-weight: 600;
		letter-spacing: 0.5px;
	}

	.home-content p {
		font-size: 1rem;
		line-height: 1.8;
		color: var(--dark);
		margin-bottom: 1rem;
		font-weight: 500;
		letter-spacing: 0.3px;
	}

	.btn-group {
		display: flex;
		gap: 1rem;
		margin: 2rem 0;
		flex-wrap: wrap;
	}

	.social-icons {
		display: flex;
		gap: 1.5rem;
		margin-top: 2rem;
	}

	.social-icons a {
		width: 50px;
		height: 50px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--gradient);
		color: var(--white);
		border-radius: 50%;
		text-decoration: none;
		font-size: 1.2rem;
		transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
		box-shadow: 0 8px 25px rgba(162, 136, 166, 0.35);
		border: 2px solid rgba(255, 255, 255, 0.3);
	}

	.social-icons a:hover {
		transform: translateY(-8px) scale(1.1);
		box-shadow: 0 12px 35px rgba(162, 136, 166, 0.5);
		border-color: rgba(255, 255, 255, 0.6);
	}

	.clouds {
		position: absolute;
		bottom: -80px;
		left: 0;
		right: 0;
		height: 120px;
		z-index: 1;
		pointer-events: none;
		width: 100%;
		overflow: hidden;
	}

	.cloud-style {
		position: absolute;
		bottom: 0;
		width: 100px;
		height: auto;
		fill: white;
		opacity: 0.7;
	}

	.cloud-1 {
		left: 5%;
		animation: moveClouds 60s linear infinite;
	}

	.cloud-2 {
		left: 35%;
		animation: moveClouds 80s linear infinite reverse;
		width: 120px;
	}

	.cloud-3 {
		left: 65%;
		animation: moveClouds 100s linear infinite;
		width: 90px;
	}

	@keyframes moveClouds {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(100vw);
		}
	}

	@media (max-width: 768px) {
		.home {
			flex-direction: column;
			padding: 3rem 5%;
		}

		.home-content {
			padding-left: 0;
			margin-top: 2rem;
		}

		.home-content h1 {
			font-size: 2rem;
		}

		.typing-text {
			font-size: 1.2rem;
		}

		.btn-group {
			flex-direction: column;
		}

		.btn-group a {
			width: 100%;
			text-align: center;
		}

		.home-img img {
			width: 200px;
			height: 200px;
		}

		.rotating-border {
			width: 220px;
			height: 220px;
		}

		.rotating-border-2 {
			width: 250px;
			height: 250px;
		}
	}

	.typing-text span::after {
		content: '|';
		animation: blink 0.7s infinite;
		margin-left: 3px;
		color: var(--primary);
	}

	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}
</style>

<script>
	const words = ["IT Student", "Web Developer", "Graphic Designer", "Scholar"];
	let i = 0;
	let timer: number | any;

	function typingEffect() {
		let word = words[i].split("");
		var loopTyping = function() {
			if (word.length > 0) {
				const span = document.querySelector('.typing-text span');
				if (span) span.innerHTML += word.shift();
			} else {
				deletingEffect();
				return false;
			}
			timer = setTimeout(loopTyping, 100);
		};
		loopTyping();
	}

	function deletingEffect() {
		let word = words[i].split("");
		var loopDeleting = function() {
			if (word.length > 0) {
				word.pop();
				const span = document.querySelector('.typing-text span');
				if (span) span.innerHTML = word.join("");
			} else {
				if (words.length > (i + 1)) {
					i++;
				} else {
					i = 0;
				}
				setTimeout(typingEffect, 500);
				return false;
			}
			timer = setTimeout(loopDeleting, 60);
		};
		setTimeout(loopDeleting, 2000);
	}

	// Start typing after component loads
	document.addEventListener('DOMContentLoaded', () => {
		typingEffect();
	});
	// Backup initialization in case DOMContentLoaded already fired
	if (document.readyState === 'complete' || document.readyState === 'interactive') {
		typingEffect();
	}
</script>
