---
import CloudIcon from '../assets/cloud.svg';
import { getEmDashCollection } from 'emdash';

let name = "Angel Marie";
let role = "IT Student";
let focus = "Web Dev & Tech";

try {
	const { entries } = await getEmDashCollection('profile');
	if (entries && entries.length > 0 && entries[0].data) {
		name = entries[0].data.name || name;
		role = entries[0].data.role || role;
	}
} catch (e) {
	console.error('Error fetching profile from EmDash:', e);
}
---

<section class="home" id="home">
	<div class="home-container">
		<div class="year">2024</div>
		<h1 class="portfolio-title">PORTFOLIO</h1>
		
		<div class="illustration-placeholder">
			<div class="character-box">
				<div class="glow-orb"></div>
				<div class="dev-card">
					<div class="card-header">
						<span class="dot red"></span>
						<span class="dot yellow"></span>
						<span class="dot green"></span>
					</div>
					<div class="card-content">
						<div class="code-line"><span class="keyword">const</span> <span class="variable">developer</span> = &#123;</div>
						<div class="code-line indent"><span class="property">name</span>: <span class="string">"{name}"</span>,</div>
						<div class="code-line indent"><span class="property">role</span>: <span class="string">"{role}"</span>,</div>
						<div class="code-line indent"><span class="property">focus</span>: <span class="string">"{focus}"</span></div>
						<div class="code-line">&#125;;</div>
					</div>
				</div>
				<div class="tech-badge badge-1"><i class="fa-solid fa-code"></i> Frontend</div>
				<div class="tech-badge badge-2"><i class="fa-solid fa-database"></i> Database</div>
				<div class="tech-badge badge-3"><i class="fa-solid fa-graduation-cap"></i> Scholar</div>
			</div>
		</div>
		
		<p class="welcome-text">WELCOME</p>
	</div>

	<div class="clouds">
		<CloudIcon class="cloud-style cloud-1" />
		<CloudIcon class="cloud-style cloud-2" />
		<CloudIcon class="cloud-style cloud-3" />
	</div>
</section>

<style>
	.home {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 5rem 8%;
		position: relative;
		background-color: var(--light);
		overflow: hidden;
	}

	.home-container {
		text-align: center;
		z-index: 1;
		width: 100%;
	}

	.year {
		font-size: 1.2rem;
		color: var(--primary);
		font-weight: 600;
		margin-bottom: 1rem;
		letter-spacing: 2px;
	}

	.portfolio-title {
		font-size: 5rem;
		font-weight: 700;
		color: var(--primary);
		margin-bottom: 2rem;
		letter-spacing: 8px;
		text-shadow: 0 4px 15px rgba(162, 136, 166, 0.2);
	}

	.illustration-placeholder {
		display: flex;
		justify-content: center;
		align-items: center;
		margin: 3rem 0;
		min-height: 320px;
		position: relative;
	}

	.character-box {
		width: 450px;
		height: 320px;
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.glow-orb {
		position: absolute;
		width: 300px;
		height: 300px;
		background: radial-gradient(circle, rgba(162, 136, 166, 0.4) 0%, transparent 70%);
		border-radius: 50%;
		z-index: 0;
		filter: blur(15px);
		animation: pulseGlow 8s infinite alternate;
	}

	@keyframes pulseGlow {
		0% { transform: scale(1); opacity: 0.6; }
		100% { transform: scale(1.1); opacity: 0.9; }
	}

	.dev-card {
		background: rgba(255, 255, 255, 0.7);
		backdrop-filter: blur(12px);
		border: 1px solid rgba(255, 255, 255, 0.5);
		border-radius: 20px;
		width: 360px;
		padding: 1.5rem;
		box-shadow: 0 20px 40px rgba(162, 136, 166, 0.15), 0 0 0 1px rgba(255, 255, 255, 0.5) inset;
		z-index: 2;
		text-align: left;
		transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
	}

	.dev-card:hover {
		transform: translateY(-8px) rotate(-1deg);
		box-shadow: 0 30px 60px rgba(162, 136, 166, 0.25);
	}

	.card-header {
		display: flex;
		gap: 6px;
		margin-bottom: 1.2rem;
	}

	.dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
	}

	.dot.red { background: #ff5f56; }
	.dot.yellow { background: #ffbd2e; }
	.dot.green { background: #27c93f; }

	.card-content {
		font-family: 'Courier New', Courier, monospace;
		font-size: 0.95rem;
		line-height: 1.6;
		color: var(--dark);
	}

	.code-line {
		margin-bottom: 0.25rem;
	}

	.code-line.indent {
		padding-left: 1.5rem;
	}

	.keyword { color: #85586f; font-weight: bold; }
	.variable { color: var(--primary); }
	.property { color: #bb9bb0; }
	.string { color: #6b4f4f; }

	.tech-badge {
		position: absolute;
		background: var(--white);
		color: var(--primary);
		padding: 0.6rem 1.2rem;
		border-radius: 50px;
		font-size: 0.85rem;
		font-weight: 600;
		box-shadow: 0 10px 25px rgba(162, 136, 166, 0.15);
		border: 1px solid rgba(255, 255, 255, 0.8);
		z-index: 3;
		display: flex;
		align-items: center;
		gap: 8px;
		animation: floatBadge 6s ease-in-out infinite;
	}

	.badge-1 {
		top: 10%;
		left: -15px;
		animation-delay: 0s;
	}

	.badge-2 {
		bottom: 15%;
		right: -15px;
		animation-delay: 2s;
	}

	.badge-3 {
		top: -20px;
		right: 20px;
		animation-delay: 4s;
	}

	@keyframes floatBadge {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-10px); }
	}

	.welcome-text {
		font-size: 1.5rem;
		color: var(--primary);
		font-weight: 600;
		letter-spacing: 3px;
		margin-top: 2rem;
	}

	.clouds {
		position: absolute;
		bottom: -80px;
		left: 0;
		right: 0;
		height: 120px;
		z-index: 1;
		pointer-events: none;
		width: 100%;
		overflow: hidden;
	}

	.cloud-style {
		position: absolute;
		bottom: 0;
		width: 100px;
		height: auto;
		fill: white;
		opacity: 0.7;
	}

	.cloud-1 {
		left: 5%;
		animation: moveClouds 60s linear infinite;
	}

	.cloud-2 {
		left: 35%;
		animation: moveClouds 80s linear infinite reverse;
		width: 120px;
	}

	.cloud-3 {
		left: 65%;
		animation: moveClouds 100s linear infinite;
		width: 90px;
	}

	@keyframes moveClouds {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(100vw);
		}
	}

	@media (max-width: 768px) {
		.home {
			padding: 3rem 5%;
		}

		.portfolio-title {
			font-size: 3rem;
			letter-spacing: 4px;
		}

		.character-box {
			width: 100%;
			height: 320px;
			max-width: 320px;
		}

		.dev-card {
			width: 100%;
		}

		.tech-badge {
			padding: 0.4rem 0.8rem;
			font-size: 0.75rem;
		}

		.badge-1 { left: -5px; }
		.badge-2 { right: -5px; }

		.welcome-text {
			font-size: 1.2rem;
		}
	}
</style>
