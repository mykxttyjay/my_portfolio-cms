---
---

<div id="loader" class="loader-container">
	<div class="loader-content">
		<div class="envelope-loader">
			<div class="envelope-flap-loader"></div>
			<div class="envelope-body-loader"></div>
			<div class="letter-loader"></div>
		</div>
		<h2 class="loader-text">Welcome...</h2>
	</div>
</div>

<style>
	.loader-container {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, #A31D1D 0%, #8B1515 100%);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 9999;
		transition: opacity 0.5s ease, visibility 0.5s ease;
	}

	.loader-container.hidden {
		opacity: 0;
		visibility: hidden;
	}

	.loader-content {
		text-align: center;
	}

	.envelope-loader {
		width: 120px;
		height: 80px;
		position: relative;
		margin: 0 auto 2rem;
		animation: envelopeBounce 1.5s ease-in-out infinite;
	}

	.envelope-body-loader {
		width: 100%;
		height: 100%;
		background: #FEF9E1;
		border-radius: 0;
		position: absolute;
		bottom: 0;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
	}

	.envelope-flap-loader {
		width: 100%;
		height: 50%;
		background: #E8DCC8;
		position: absolute;
		top: 0;
		clip-path: polygon(0 0, 50% 100%, 100% 0);
		transform-origin: top center;
		animation: flapOpen 1.5s ease-in-out infinite;
		z-index: 2;
	}

	.letter-loader {
		width: 80%;
		height: 60%;
		background: white;
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		border-radius: 0;
		box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
		animation: letterSlide 1.5s ease-in-out infinite;
	}

	.letter-loader::before {
		content: '';
		position: absolute;
		width: 60%;
		height: 3px;
		background: #A31D1D;
		top: 30%;
		left: 20%;
		border-radius: 2px;
	}

	.letter-loader::after {
		content: '';
		position: absolute;
		width: 60%;
		height: 3px;
		background: #A31D1D;
		top: 50%;
		left: 20%;
		border-radius: 2px;
	}

	.loader-text {
		font-size: 1.5rem;
		font-weight: 700;
		color: #FEF9E1;
		font-family: 'Poppins', sans-serif;
		letter-spacing: 2px;
		animation: textPulse 1.5s ease-in-out infinite;
	}

	@keyframes envelopeBounce {
		0%, 100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-20px);
		}
	}

	@keyframes flapOpen {
		0%, 100% {
			transform: rotateX(0deg);
		}
		50% {
			transform: rotateX(-180deg);
		}
	}

	@keyframes letterSlide {
		0%, 100% {
			transform: translate(-50%, -50%);
		}
		50% {
			transform: translate(-50%, -80%);
		}
	}

	@keyframes textPulse {
		0%, 100% {
			opacity: 1;
		}
		50% {
			opacity: 0.5;
		}
	}
</style>

<script>
	// Hide loader when page is fully loaded
	window.addEventListener('load', () => {
		const loader = document.getElementById('loader');
		if (loader) {
			setTimeout(() => {
				loader.classList.add('hidden');
				// Remove from DOM after transition
				setTimeout(() => {
					loader.remove();
				}, 500);
			}, 3000); // Show loader for 3 seconds
		}
	});
</script>
