<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Enhanced Loader</title>

<style>
/* =========================
   LOADER CONTAINER
========================= */
.loader-container {
	position: fixed;
	inset: 0;
	background: radial-gradient(circle at top, #B22222, #6E0F0F);
	display: flex;
	align-items: center;
	justify-content: center;
	flex-direction: column;
	z-index: 9999;
	transition: opacity 0.8s ease, transform 0.8s ease;
	overflow: hidden;
}

.loader-container.hidden {
	opacity: 0;
	transform: scale(1.05);
	pointer-events: none;
}

/* ambient glow */
.loader-container::before {
	content: '';
	position: absolute;
	width: 500px;
	height: 500px;
	background: rgba(255,255,255,0.08);
	filter: blur(100px);
	border-radius: 50%;
	animation: floatGlow 4s ease-in-out infinite;
}

@keyframes floatGlow {
	0%, 100% { transform: translateY(0); }
	50% { transform: translateY(-40px); }
}

.loader-content {
	text-align: center;
	z-index: 2;
}

/* =========================
   ENVELOPE
========================= */
.envelope-loader {
	width: 130px;
	height: 90px;
	position: relative;
	margin-bottom: 1.5rem;
	animation: envelopeFloat 3s ease-in-out infinite, envelopeRotate 6s ease-in-out infinite;
	transform-style: preserve-3d;
}

@keyframes envelopeFloat {
	0%, 100% { 
		transform: translateY(0) rotateZ(0deg);
	}
	25% {
		transform: translateY(-20px) rotateZ(-3deg);
	}
	50% { 
		transform: translateY(-10px) rotateZ(0deg);
	}
	75% {
		transform: translateY(-20px) rotateZ(3deg);
	}
}

@keyframes envelopeRotate {
	0%, 100% {
		transform: perspective(600px) rotateY(0deg);
	}
	50% {
		transform: perspective(600px) rotateY(15deg);
	}
}

/* shadow */
.envelope-shadow {
	position: absolute;
	bottom: -10px;
	left: 50%;
	transform: translateX(-50%);
	width: 70%;
	height: 10px;
	background: rgba(0,0,0,0.25);
	filter: blur(8px);
	border-radius: 50%;
	animation: shadowPulse 3s ease-in-out infinite;
}

@keyframes shadowPulse {
	0%, 100% {
		transform: translateX(-50%) scale(1);
		opacity: 0.25;
	}
	25% {
		transform: translateX(-50%) scale(0.7);
		opacity: 0.15;
	}
	50% {
		transform: translateX(-50%) scale(0.85);
		opacity: 0.2;
	}
	75% {
		transform: translateX(-50%) scale(0.7);
		opacity: 0.15;
	}
}

/* body */
.envelope-body {
	position: absolute;
	width: 100%;
	height: 100%;
	background: #eadfcb;
	border-radius: 0;
	box-shadow: 0 20px 40px rgba(0,0,0,0.35);
	animation: bodyGlow 3s ease-in-out infinite;
}

@keyframes bodyGlow {
	0%, 100% {
		box-shadow: 0 20px 40px rgba(0,0,0,0.35);
	}
	50% {
		box-shadow: 0 25px 50px rgba(0,0,0,0.4), 0 0 20px rgba(234, 223, 203, 0.3);
	}
}

/* flap */
.envelope-flap {
	position: absolute;
	width: 100%;
	height: 100%;
	background: #E8DCC8;
	clip-path: polygon(0 0, 50% 55%, 100% 0);
	transform-origin: top;
	animation: flapWave 3s ease-in-out infinite;
}

@keyframes flapWave {
	0%, 100% { 
		transform: rotateX(0deg);
		filter: brightness(1);
	}
	25% {
		transform: rotateX(-180deg);
		filter: brightness(1.1);
	}
	50% { 
		transform: rotateX(-160deg);
		filter: brightness(1.05);
	}
	75% {
		transform: rotateX(-180deg);
		filter: brightness(1.1);
	}
}

/* letter */
.letter {
	position: absolute;
	width: 75%;
	height: 65%;
	background: white;
	top: 50%;
	left: 50%;
	transform: translate(-50%, -50%);
	border-radius: 0;
	box-shadow: 0 10px 20px rgba(0,0,0,0.25);
	animation: letterRise 3s ease-in-out infinite;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	gap: 3px;
}

@keyframes letterRise {
	0%, 100% { 
		transform: translate(-50%, -50%) scale(1);
		box-shadow: 0 10px 20px rgba(0,0,0,0.25);
	}
	25% { 
		transform: translate(-50%, -95%) scale(1.05);
		box-shadow: 0 15px 30px rgba(0,0,0,0.3);
	}
	50% { 
		transform: translate(-50%, -85%) scale(1.02);
		box-shadow: 0 12px 25px rgba(0,0,0,0.28);
	}
	75% { 
		transform: translate(-50%, -95%) scale(1.05);
		box-shadow: 0 15px 30px rgba(0,0,0,0.3);
	}
}

.letter-line {
	width: 70%;
	height: 2px;
	background: linear-gradient(90deg, transparent, #B22222, transparent);
	border-radius: 2px;
	animation: lineShimmer 2s ease-in-out infinite;
}

.letter-line:nth-child(1) { animation-delay: 0s; }
.letter-line:nth-child(2) { animation-delay: 0.2s; }
.letter-line:nth-child(3) { animation-delay: 0.4s; }

@keyframes lineShimmer {
	0%, 100% {
		opacity: 0.6;
		transform: scaleX(1);
	}
	50% {
		opacity: 1;
		transform: scaleX(1.1);
	}
}

@keyframes letterRise {
	0%, 100% { transform: translate(-50%, -50%); }
	50% { transform: translate(-50%, -85%); }
}

/* =========================
   LOADING TEXT
========================= */
.loading-text {
	font-family: 'Playfair Display', Georgia, serif;
	font-size: 1rem;
	font-weight: 600;
	color: #eadfcb;
	letter-spacing: 1px;
	transition: opacity 0.3s ease;
	text-align: center;
	margin-top: 0.5rem;
}

@keyframes pulse {
	0%, 100% { opacity: 0.6; }
	50% { opacity: 1; }
}

/* =========================
   PROGRESS BAR
========================= */
.progress-container {
	width: 130px;
	height: 4px;
	background: rgba(255, 255, 255, 0.2);
	border-radius: 10px;
	margin-top: 0.3rem;
	overflow: hidden;
	position: relative;
	transition: opacity 0.3s ease;
}

.progress-bar {
	height: 100%;
	background: #eadfcb;
	border-radius: 10px;
	animation: progress 2.8s ease-out forwards;
	box-shadow: 0 0 8px rgba(234, 223, 203, 0.4);
}

@keyframes progress {
	0% { width: 0%; }
	100% { width: 100%; }
}

/* =========================
   LETTER UNFOLD ANIMATION
========================= */
@keyframes letterUnfold {
	0% {
		transform: translate(-50%, -50%) scale(1);
		opacity: 1;
		border-radius: 0;
	}
	50% {
		transform: translate(-50%, -50%) scale(3);
		opacity: 1;
		border-radius: 0;
	}
	100% {
		transform: translate(-50%, -50%) scale(20);
		opacity: 0;
		border-radius: 0;
	}
}
</style>
</head>

<body>

<!-- =========================
     LOADER
========================= -->
<div id="loader" class="loader-container">

	<div class="loader-content">

		<div class="envelope-loader">
			<div class="envelope-shadow"></div>
			<div class="envelope-body"></div>
			<div class="envelope-flap"></div>
			<div class="letter">
				<div class="letter-line"></div>
				<div class="letter-line"></div>
				<div class="letter-line"></div>
			</div>
		</div>

		<!-- Loading Text and Progress Bar -->
		<div class="loading-text">Loading...</div>
		<div class="progress-container">
			<div class="progress-bar"></div>
		</div>

	</div>
</div>

<script>
/* =========================
   LOADER EXIT LOGIC
========================= */
window.addEventListener('load', () => {
	const loader = document.getElementById('loader');
	const letter = document.querySelector('.letter') as HTMLElement;
	const envelopeLoader = document.querySelector('.envelope-loader') as HTMLElement;
	const loadingText = document.querySelector('.loading-text') as HTMLElement;
	const progressContainer = document.querySelector('.progress-container') as HTMLElement;

	// wait for animation + progress bar to complete
	setTimeout(() => {
		if (!loader || !letter || !envelopeLoader) return;

		// Hide loading text and progress bar
		if (loadingText) loadingText.style.opacity = '0';
		if (progressContainer) progressContainer.style.opacity = '0';

		// Hide envelope elements except letter
		envelopeLoader.style.animation = 'none';
		document.querySelector('.envelope-flap')?.remove();
		document.querySelector('.envelope-body')?.remove();
		document.querySelector('.envelope-shadow')?.remove();

		// Make letter expand to full screen
		letter.style.animation = 'letterUnfold 1.2s ease-in-out forwards';
		
		// Change loader background to match letter
		setTimeout(() => {
			loader.style.background = 'white';
		}, 400);

		// After unfold animation, fade out loader
		setTimeout(() => {
			loader.classList.add('hidden');

			// remove from DOM after fade out
			setTimeout(() => {
				loader.remove();
			}, 500);
		}, 1200);

	}, 2800);
});
</script>

</body>
</html>