<footer class="footer">
	<div class="footer-content">
		<div class="footer-left">
			<h3 class="footer-title">Angel Marie Sabido</h3>
			<p class="footer-subtitle">Designer & Developer</p>
		</div>

		<div class="footer-right">
			<div class="social-links">
				<a href="https://linkedin.com/in/gelmarie" target="_blank" rel="noopener noreferrer" class="social-link" title="LinkedIn">
					<i class="fa-brands fa-linkedin"></i>
				</a>
				<a href="https://github.com/mykxttyjay" target="_blank" rel="noopener noreferrer" class="social-link" title="GitHub">
					<i class="fa-brands fa-github"></i>
				</a>
				<a href="https://instagram.com/gelmarieee" target="_blank" rel="noopener noreferrer" class="social-link" title="Instagram">
					<i class="fa-brands fa-instagram"></i>
				</a>
				<a href="mailto:sabidoangel.uc@gmail.com" class="social-link" title="Email">
					<i class="fa-solid fa-envelope"></i>
				</a>
			</div>
		</div>
	</div>

	<div class="footer-bottom">
		<p class="footer-text">© 2026 Angel Marie Sabido. All rights reserved.</p>
	</div>
</footer>

<style>
	.footer {
		background-color: #4A1215;
		color: #FEF9E1;
		padding: 3rem 8%;
		position: relative;
		overflow: hidden;
	}

	.footer::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 150 150' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.03' numOctaves='4' result='noise' seed='1' /%3E%3CfeColorMatrix in='noise' type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' fill='%23000000' filter='url(%23noiseFilter)' opacity='0.12'/%3E%3C/svg%3E");
		background-size: 150px 150px;
		pointer-events: none;
		z-index: 0;
		mix-blend-mode: overlay;
	}

	.footer-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		position: relative;
		z-index: 1;
		gap: 2rem;
		margin-bottom: 2rem;
	}

	.footer-left {
		text-align: left;
	}

	.footer-right {
		text-align: right;
	}

	.footer-title {
		font-family: 'Playfair Display', Georgia, serif;
		font-size: 1.8rem;
		font-weight: 700;
		color: #FEF9E1;
		margin-bottom: 0.5rem;
		font-style: italic;
		letter-spacing: 0.5px;
	}

	.footer-subtitle {
		font-size: 0.95rem;
		color: rgba(254, 249, 225, 0.8);
		font-weight: 500;
	}

	.social-links {
		display: flex;
		justify-content: flex-end;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.social-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 45px;
		height: 45px;
		background: rgba(254, 249, 225, 0.1);
		border: 2px solid rgba(254, 249, 225, 0.3);
		border-radius: 50%;
		color: #FEF9E1;
		font-size: 1.2rem;
		transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
		text-decoration: none;
	}

	.social-link:hover {
		background: #A31D1D;
		border-color: #A31D1D;
		transform: translateY(-3px) scale(1.1);
		box-shadow: 0 8px 20px rgba(163, 29, 29, 0.3);
	}

	.footer-bottom {
		border-top: 1px solid rgba(254, 249, 225, 0.2);
		padding-top: 1.5rem;
		text-align: center;
		position: relative;
		z-index: 1;
	}

	.footer-text {
		font-size: 0.9rem;
		color: rgba(254, 249, 225, 0.7);
		margin: 0;
	}

	@media (max-width: 768px) {
		.footer {
			padding: 2rem 1.5rem;
		}

		.footer-content {
			flex-direction: column;
			align-items: flex-start;
			gap: 1.5rem;
			margin-bottom: 1.5rem;
		}

		.footer-right {
			text-align: left;
			width: 100%;
		}

		.social-links {
			justify-content: flex-start;
		}

		.footer-title {
			font-size: 1.5rem;
		}

		.social-link {
			width: 40px;
			height: 40px;
			font-size: 1rem;
		}

		.footer-text {
			font-size: 0.85rem;
		}
	}

	@media (max-width: 480px) {
		.footer {
			padding: 1.5rem 1rem;
		}

		.footer-content {
			gap: 1rem;
			margin-bottom: 1rem;
		}

		.footer-title {
			font-size: 1.3rem;
		}

		.social-links {
			gap: 1rem;
		}

		.social-link {
			width: 38px;
			height: 38px;
			font-size: 0.9rem;
		}
	}
</style>
