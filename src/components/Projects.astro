---
---

<section class="projects" id="projects">
	<h2 class="heading">My <span>Projects</span></h2>
	<div class="projects-container">
		<div class="project-card">
			<div class="project-icon">
				<i class="fa-solid fa-laptop-code"></i>
			</div>
			<h3>Portfolio Website</h3>
			<p>A responsive personal portfolio website built with HTML, CSS, and JavaScript showcasing my skills and projects.</p>
			<div class="project-tags">
				<span class="tag">HTML</span>
				<span class="tag">CSS</span>
				<span class="tag">JavaScript</span>
			</div>
		</div>
		<div class="project-card">
			<div class="project-icon">
				<i class="fa-solid fa-mobile-screen"></i>
			</div>
			<h3>Mobile App Design</h3>
			<p>UI/UX design for a mobile application focused on user experience and modern design principles.</p>
			<div class="project-tags">
				<span class="tag">UI/UX</span>
				<span class="tag">Figma</span>
				<span class="tag">Design</span>
			</div>
		</div>
		<div class="project-card">
			<div class="project-icon">
				<i class="fa-solid fa-code"></i>
			</div>
			<h3>Web Application</h3>
			<p>Full-stack web application with user authentication, data visualization, and real-time updates.</p>
			<div class="project-tags">
				<span class="tag">React</span>
				<span class="tag">Node.js</span>
				<span class="tag">MongoDB</span>
			</div>
		</div>
	</div>
</section>

<style>
	.projects {
		background: var(--primary);
		padding: 5rem 0;
	}

	.projects .heading {
		color: var(--white);
	}

	.projects .heading span {
		-webkit-text-fill-color: var(--accent);
		color: var(--accent);
	}

	.projects-container {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2.5rem;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.project-card {
		background: rgba(255, 255, 255, 0.08);
		backdrop-filter: blur(12px);
		border: 1px solid rgba(255, 255, 255, 0.15);
		padding: 2.5rem 2rem;
		border-radius: 24px;
		box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1), 0 0 0 1px rgba(255, 255, 255, 0.05) inset;
		transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), border-color 0.4s ease, box-shadow 0.4s ease;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.project-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(255, 255, 255, 0.1) inset;
		border-color: rgba(255, 255, 255, 0.3);
	}

	.project-icon {
		width: 60px;
		height: 60px;
		background: rgba(255, 255, 255, 0.15);
		border-radius: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--white);
		font-size: 1.5rem;
		margin-bottom: 1.5rem;
		border: 1px solid rgba(255, 255, 255, 0.2);
		transition: transform 0.3s ease, border-radius 0.3s ease, background 0.3s ease;
	}

	.project-card:hover .project-icon {
		transform: scale(1.1) rotate(-8deg);
		border-radius: 50%;
		background: var(--white);
		color: var(--primary);
	}

	.project-card h3 {
		font-size: 1.45rem;
		color: var(--white);
		margin-bottom: 1rem;
		font-weight: 700;
	}

	.project-card p {
		color: rgba(255, 255, 255, 0.85);
		line-height: 1.7;
		margin-bottom: 1.5rem;
		font-size: 0.95rem;
	}

	.project-tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		margin-top: auto; /* Push tags to the bottom of the card */
	}

	.tag {
		padding: 0.4rem 0.9rem;
		background: rgba(255, 255, 255, 0.1);
		border: 1px solid rgba(255, 255, 255, 0.15);
		border-radius: 50px;
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--white);
		transition: all 0.3s ease;
		cursor: default;
	}

	.tag:hover {
		background: var(--white);
		color: var(--primary);
		transform: translateY(-2px);
		box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
	}
</style>
