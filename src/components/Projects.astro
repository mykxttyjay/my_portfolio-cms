---
import projectsData from '../data/projects.json'

// Function to generate a beautiful deterministic gradient based on a string
function getDeterministicTheme(str: string, index: number) {
	const gradients = [
		{ bg: "linear-gradient(135deg, #ff7a7a 0%, #ff5252 100%)", text: "#ffffff", label: str.toUpperCase() },
		{ bg: "linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%)", text: "#ffffff", label: str.toUpperCase() },
		{ bg: "linear-gradient(135deg, #11998e 0%, #38ef7d 100%)", text: "#ffffff", label: str.toUpperCase() },
		{ bg: "linear-gradient(135deg, #1d976c 0%, #93f9b9 100%)", text: "#ffffff", label: str.toUpperCase() },
		{ bg: "radial-gradient(circle, #232526 0%, #0f2027 100%)", text: "#d4af37", label: str.toUpperCase() },
		{ bg: "linear-gradient(135deg, #667eea 0%, #764ba2 100%)", text: "#ffffff", label: str.toUpperCase() },
		{ bg: "linear-gradient(135deg, #f093fb 0%, #f5576c 100%)", text: "#ffffff", label: str.toUpperCase() },
		{ bg: "linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)", text: "#ffffff", label: str.toUpperCase() }
	];
	return gradients[index % gradients.length];
}

// Icon mapping
const iconMap: Record<string, string> = {
	'utensils': 'fa-solid fa-martini-glass-citrus',
	'car': 'fa-solid fa-car',
	'bolt': 'fa-solid fa-bolt',
	'wind': 'fa-solid fa-temperature-half',
	'droplet': 'fa-solid fa-wrench'
}

// Transform data into the format needed for display
const projectsList = projectsData.map((project, index) => {
	// Generate screenshot URL from the project URL using a free screenshot service
	let screenshotUrl = "";
	if (project.link) {
		const encodedUrl = encodeURIComponent(project.link);
		screenshotUrl = `https://api.microlink.io/?url=${encodedUrl}&screenshot=true&meta=false&embed=screenshot.url`;
	}
	
	return {
		title: project.title,
		description: project.description,
		icon: iconMap[project.icon] || "fa-solid fa-code",
		tags: project.tags,
		project_url: project.link,
		screenshot_url: screenshotUrl,
		theme: getDeterministicTheme(project.title, index)
	};
});

// Stagger them into row1 and row2
const row1Base = projectsList.filter((_, i) => i % 2 === 0);
const row2Base = projectsList.filter((_, i) => i % 2 !== 0);

// Double/Triple them to build beautiful infinite scrolling tracks
const row1List = [...row1Base, ...row1Base, ...row1Base];
const row2List = [...row2Base, ...row2Base, ...row2Base];
---

<section class="projects" id="projects">
	<h2 class="heading"><span>Projects</span></h2>
	
	<div class="projects-carousel-container">
		<!-- Row 1: moves left as you scroll down -->
		<div class="projects-track-wrapper track-row-1" data-direction="-1">
			<div class="projects-track">
				{row1List.map((project) => (
					<div class="project-mockup-card" data-url={project.project_url}>
						{/* browser header */}
						<div class="browser-header">
							<div class="browser-dots">
								<span class="dot red"></span>
								<span class="dot yellow"></span>
								<span class="dot green"></span>
							</div>
							<div class="browser-address">{project.project_url ? new URL(project.project_url).hostname : project.title.toLowerCase().replace(/ /g, '-')}</div>
						</div>
						{/* canvas */}
						<div class="mockup-canvas" style={project.screenshot_url ? '' : `background: ${project.theme.bg}`}>
							{project.screenshot_url ? (
								<img
									src={project.screenshot_url}
									alt={`${project.title} screenshot`}
									class="mockup-screenshot"
									loading="lazy"
								/>
							) : (
								<div class="canvas-content">
									<div class="canvas-icon" style={`color: ${project.theme.text}`}><i class={project.icon}></i></div>
									<h4 style={`color: ${project.theme.text}`}>{project.theme.label}</h4>
								</div>
							)}
						</div>
						{/* hover detail card */}
						<div class="project-detail-overlay">
							<div class="overlay-content">
								<h3>{project.title}</h3>
								<p>{project.description}</p>
								<div class="project-tags">
									{project.tags.map((tag: string) => (
										<span class="tag">{tag}</span>
									))}
								</div>
								{project.project_url && (
									<a href={project.project_url} target="_blank" class="project-btn" rel="noopener noreferrer">
										View Live
									</a>
								)}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>

		<!-- Row 2: moves right as you scroll down -->
		<div class="projects-track-wrapper track-row-2" data-direction="1">
			<div class="projects-track">
				{row2List.map((project) => (
					<div class="project-mockup-card" data-url={project.project_url}>
						{/* browser header */}
						<div class="browser-header">
							<div class="browser-dots">
								<span class="dot red"></span>
								<span class="dot yellow"></span>
								<span class="dot green"></span>
							</div>
							<div class="browser-address">{project.project_url ? new URL(project.project_url).hostname : project.title.toLowerCase().replace(/ /g, '-')}</div>
						</div>
						{/* canvas */}
						<div class="mockup-canvas" style={project.screenshot_url ? '' : `background: ${project.theme.bg}`}>
							{project.screenshot_url ? (
								<img
									src={project.screenshot_url}
									alt={`${project.title} screenshot`}
									class="mockup-screenshot"
									loading="lazy"
								/>
							) : (
								<div class="canvas-content">
									<div class="canvas-icon" style={`color: ${project.theme.text}`}><i class={project.icon}></i></div>
									<h4 style={`color: ${project.theme.text}`}>{project.theme.label}</h4>
								</div>
							)}
						</div>
						{/* hover detail card */}
						<div class="project-detail-overlay">
							<div class="overlay-content">
								<h3>{project.title}</h3>
								<p>{project.description}</p>
								<div class="project-tags">
									{project.tags.map((tag: string) => (
										<span class="tag">{tag}</span>
									))}
								</div>
								{project.project_url && (
									<a href={project.project_url} target="_blank" class="project-btn" rel="noopener noreferrer">
										View Live
									</a>
								)}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>

<script>
	function initCarousel() {
		const tracks = document.querySelectorAll('.projects-track') as NodeListOf<HTMLElement>;
		const projectsSection = document.getElementById('projects');

		if (!projectsSection || tracks.length === 0) return;

		// 1. Scroll-driven Parallax Animation
		const handleScroll = () => {
			const sectionRect = projectsSection.getBoundingClientRect();
			const windowHeight = window.innerHeight;

			// Check if the projects section is visible in the viewport
			if (sectionRect.top < windowHeight && sectionRect.bottom > 0) {
				const totalScrollableHeight = windowHeight + sectionRect.height;
				const currentScroll = windowHeight - sectionRect.top;
				const scrollPercent = Math.min(Math.max(currentScroll / totalScrollableHeight, 0), 1);

				tracks.forEach((track) => {
					const directionAttr = track.parentElement?.getAttribute('data-direction');
					const direction = parseFloat(directionAttr || '1');
					
					// Base shifts to spread the rows nicely, plus the parallax scroll offset
					const baseTranslate = direction === 1 ? -400 : -50;
					const scrollDisplacement = (scrollPercent - 0.5) * 450 * direction;
					const finalTranslate = baseTranslate + scrollDisplacement;
					
					track.style.transform = `translateX(${finalTranslate}px)`;
				});
			}
		};

		window.addEventListener('scroll', handleScroll, { passive: true });
		// Trigger once initially to position them
		handleScroll();

		// 2. Click navigation on cards
		const cards = document.querySelectorAll('.project-mockup-card');
		cards.forEach(card => {
			card.addEventListener('click', (e: Event) => {
				const target = e.target as HTMLElement;
				// If user clicked the "View Live" button or external tag, don't trigger general card click
				if (target.closest('a') || target.closest('.tag')) return;

				const url = card.getAttribute('data-url');
				if (url) {
					window.open(url, '_blank', 'noopener,noreferrer');
				}
			});
		});

		// 3. Drag and Swipe Support
		tracks.forEach(track => {
			let isDown = false;
			let startX: number;
			let initialTranslate = 0;

			// Parse current translate from style transform
			const getTranslateX = () => {
				const style = window.getComputedStyle(track);
				const transform = style.transform;
				if (transform === 'none') return 0;
				
				// Parse matrix(1, 0, 0, 1, translateX, translateY)
				const matrix = transform.match(/matrix\(([^,]+, ){4}([^,]+),/);
				if (matrix && matrix[2]) {
					return parseFloat(matrix[2]);
				}
				return 0;
			};

			const handleDown = (pageX: number) => {
				isDown = true;
				track.classList.add('active');
				startX = pageX - track.offsetLeft;
				initialTranslate = getTranslateX();
				track.style.transition = 'none'; // Disable transition during drag
			};

			const handleUp = () => {
				if (!isDown) return;
				isDown = false;
				track.classList.remove('active');
				track.style.transition = 'transform 0.3s cubic-bezier(0.1, 0.8, 0.2, 1)';
			};

			const handleMove = (pageX: number) => {
				if (!isDown) return;
				const x = pageX - track.offsetLeft;
				const walk = (x - startX) * 1.5; // Drag sensitivity multiplier
				track.style.transform = `translateX(${initialTranslate + walk}px)`;
			};

			// Mouse Events
			track.addEventListener('mousedown', (e: MouseEvent) => {
				handleDown(e.pageX);
			});

			track.addEventListener('mouseleave', handleUp);
			track.addEventListener('mouseup', handleUp);

			track.addEventListener('mousemove', (e: MouseEvent) => {
				handleMove(e.pageX);
			});

			// Touch Events for Mobile
			track.addEventListener('touchstart', (e: TouchEvent) => {
				if (e.touches[0]) {
					handleDown(e.touches[0].pageX);
				}
			}, { passive: true });

			track.addEventListener('touchend', handleUp);

			track.addEventListener('touchmove', (e: TouchEvent) => {
				if (isDown && e.touches[0]) {
					handleMove(e.touches[0].pageX);
				}
			}, { passive: true });
		});
	}

	// Run on initial load
	initCarousel();
	// Run on Astro page navigation if custom page transitions are ever added
	document.addEventListener('astro:page-load', initCarousel);
</script>

<style>
	.projects {
		background: #F5F0E8;
		padding: 3rem 0;
		position: relative;
		overflow: hidden;
	}

	.projects::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='crumple'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.04' numOctaves='5' result='noise' seed='3' /%3E%3CfeDisplacementMap in='SourceGraphic' in2='noise' scale='8' xChannelSelector='R' yChannelSelector='G'/%3E%3C/filter%3E%3Crect width='200' height='200' fill='%23F5F0E8' filter='url(%23crumple)' opacity='0.4'/%3E%3C/svg%3E");
		background-size: 200px 200px;
		pointer-events: none;
		z-index: 0;
		mix-blend-mode: multiply;
	}

	.projects .heading {
		color: #4A1215;
		position: relative;
		z-index: 2;
		font-family: 'Playfair Display', Georgia, serif;
		font-size: 56px;
		font-weight: 900;
		letter-spacing: -1px;
		font-style: italic;
		text-align: center;
		margin-bottom: 1rem;
	}

	.projects .heading span {
		-webkit-text-fill-color: #4A1215;
		color: #4A1215;
	}

	.projects-carousel-container {
		display: flex;
		flex-direction: column;
		gap: 3rem;
		width: 100vw;
		position: relative;
		left: 50%;
		right: 50%;
		margin-left: -50vw;
		margin-right: -50vw;
		overflow: hidden;
		padding: 2rem 0;
		z-index: 2;
	}

	.projects-track-wrapper {
		width: 100%;
		overflow: visible;
		cursor: grab;
	}

	.projects-track-wrapper:active {
		cursor: grabbing;
	}

	.projects-track {
		display: flex;
		gap: 2.5rem;
		padding: 0 4rem;
		width: max-content;
		will-change: transform;
		transform: translateX(0px);
		transition: transform 0.4s cubic-bezier(0.1, 0.8, 0.2, 1);
	}

	.project-mockup-card {
		position: relative;
		width: 440px;
		height: 270px;
		border-radius: 12px;
		background: #FFFEF8;
		box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
		overflow: hidden;
		display: flex;
		flex-direction: column;
		cursor: pointer;
		transition: none;
		user-select: none;
		border: 2px solid #4A1215;
	}

	/* Browser Chrome Styles - Modified to look like letter header */
	.browser-header {
		height: 40px;
		background: #FFFEF8;
		display: flex;
		align-items: center;
		padding: 0 1.2rem;
		border-bottom: 2px solid #4A1215;
		position: relative;
		z-index: 3;
	}

	.browser-dots {
		display: none;
	}

	.browser-address {
		position: static;
		transform: none;
		font-size: 0.75rem;
		color: #4A1215;
		font-family: 'Playfair Display', Georgia, serif;
		font-style: italic;
		background: transparent;
		padding: 0;
		border-radius: 0;
		width: auto;
		text-align: left;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		font-weight: 600;
	}

	.browser-address::before {
		content: 'To: ';
		font-weight: 700;
	}

	/* Mock Website Canvas - Letter content area */
	.mockup-canvas {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: hidden;
		padding: 1rem;
		z-index: 2;
		background: #FFFEF8;
	}

	.mockup-canvas:not(:has(.mockup-screenshot))::before {
		content: '';
		position: absolute;
		inset: 0;
		opacity: 0.03;
		background-image: 
			repeating-linear-gradient(
				0deg,
				transparent,
				transparent 31px,
				#4A1215 31px,
				#4A1215 32px
			);
		z-index: 1;
		pointer-events: none;
	}

	/* Real screenshot image fills the card canvas */
	.mockup-screenshot {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top center;
		display: block;
		transition: none;
		filter: brightness(0.97);
	}

	.canvas-content {
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.8rem;
		width: 90%;
		z-index: 2;
		padding: 1rem;
	}

	.canvas-icon {
		font-size: 2.5rem;
		margin-bottom: 0.2rem;
		color: #A31D1D;
		opacity: 0.9;
		transition: none;
	}

	.canvas-content h4 {
		font-family: 'Playfair Display', serif;
		font-size: 1.3rem;
		font-weight: 700;
		line-height: 1.3;
		letter-spacing: 0.5px;
		color: #4A1215;
		margin: 0;
		font-style: italic;
	}

	/* Hover Detail Overlay with letter styling */
	.project-detail-overlay {
		position: absolute;
		inset: 0;
		background: rgba(255, 254, 248, 0.98);
		backdrop-filter: blur(8px);
		opacity: 0;
		visibility: hidden;
		transform: scale(0.95);
		transition: 
			opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1), 
			visibility 0.4s,
			transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		z-index: 10;
		border: 2px solid #4A1215;
		border-radius: 12px;
		box-shadow: 
			0 10px 40px rgba(74, 18, 21, 0.15),
			inset 0 0 0 1px rgba(163, 29, 29, 0.1);
	}

	.project-mockup-card:hover .project-detail-overlay {
		opacity: 1;
		visibility: visible;
		transform: scale(1);
	}

	.overlay-content {
		color: #4A1215;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		width: 100%;
		height: 100%;
		justify-content: center;
		text-align: left;
		animation: fadeInUp 0.5s ease-out 0.1s both;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(15px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.overlay-content h3 {
		font-family: 'Playfair Display', serif;
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0 0 0.1rem 0;
		color: #4A1215;
		font-style: italic;
		animation: slideInLeft 0.4s ease-out 0.15s both;
	}

	.overlay-content p {
		font-family: 'EB Garamond', Georgia, serif;
		font-size: 0.9rem;
		line-height: 1.6;
		margin: 0 0 0.4rem 0;
		color: #4A1215;
		text-align: justify;
		animation: fadeIn 0.5s ease-out 0.25s both;
	}

	@keyframes fadeIn {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	.project-tags {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
	}

	.tag {
		padding: 0.25rem 0.75rem;
		background: transparent;
		border: 1.5px solid #4A1215;
		border-radius: 6px;
		font-size: 0.7rem;
		font-weight: 600;
		color: #4A1215;
		transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
		font-family: 'Playfair Display', serif;
		animation: popIn 0.4s ease-out calc(0.3s + var(--tag-index) * 0.05s) both;
	}

	.tag:nth-child(1) { --tag-index: 0; }
	.tag:nth-child(2) { --tag-index: 1; }
	.tag:nth-child(3) { --tag-index: 2; }
	.tag:nth-child(4) { --tag-index: 3; }
	.tag:nth-child(5) { --tag-index: 4; }

	@keyframes popIn {
		from {
			opacity: 0;
			transform: scale(0.8) translateY(5px);
		}
		to {
			opacity: 1;
			transform: scale(1) translateY(0);
		}
	}

	.tag:hover {
		background: #4A1215;
		color: #FFFEF8;
		transform: translateY(-2px) scale(1.05);
		box-shadow: 0 4px 8px rgba(74, 18, 21, 0.2);
	}

	.project-btn {
		margin-top: 0.8rem;
		align-self: flex-start;
		padding: 0.75rem 1.5rem;
		background: #A31D1D;
		color: #FFFEF8;
		font-size: 1rem;
		font-weight: 700;
		border-radius: 8px;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		box-shadow: 0 4px 10px rgba(74, 18, 21, 0.2);
		transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
		font-family: 'Playfair Display', serif;
		border: 2px solid #4A1215;
		animation: slideInUp 0.4s ease-out 0.4s both;
		position: relative;
		overflow: hidden;
	}

	@keyframes slideInUp {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.project-btn::before {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		width: 0;
		height: 0;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.2);
		transform: translate(-50%, -50%);
		transition: width 0.6s ease, height 0.6s ease;
	}

	.project-btn:hover::before {
		width: 300px;
		height: 300px;
	}

	.project-btn:hover {
		background: #4A1215;
		transform: translateY(-3px) scale(1.05);
		box-shadow: 0 8px 20px rgba(74, 18, 21, 0.4);
	}

	@media (max-width: 992px) {
		.projects {
			padding: 3rem 0 4rem 0;
		}

		.projects .heading {
			font-size: 45px;
			margin-bottom: 2rem;
		}
	}

	@media (max-width: 768px) {
		.projects-carousel-container {
			gap: 1.8rem;
		}

		.projects-track {
			gap: 1.5rem;
			padding: 0 2rem;
		}

		.project-mockup-card {
			width: 310px;
			height: 200px;
			border-radius: 12px;
		}

		.browser-header {
			height: 28px;
			padding: 0 0.8rem;
		}

		.browser-address {
			width: 140px;
			font-size: 0.65rem;
		}

		.canvas-content h4 {
			font-size: 0.95rem;
		}

		.canvas-icon {
			font-size: 1.6rem;
		}

		.project-detail-overlay {
			padding: 1.2rem;
			border-radius: 12px;
		}

		.overlay-content h3 {
			font-size: 1.25rem;
		}

		.overlay-content p {
			font-size: 0.76rem;
			line-height: 1.45;
			margin-bottom: 0.3rem;
		}

		.tag {
			padding: 0.2rem 0.6rem;
			font-size: 0.68rem;
		}

		.project-btn {
			padding: 0.4rem 0.9rem;
			font-size: 0.75rem;
			margin-top: 0.5rem;
		}
	}
</style>
