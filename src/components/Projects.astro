---
import { getEmDashCollection } from 'emdash';

let projectsList = [
	{
		title: "Portfolio Website",
		description: "A responsive personal portfolio website built with HTML, CSS, and JavaScript showcasing my skills and projects.",
		icon: "fa-solid fa-laptop-code",
		tags: ["HTML", "CSS", "JavaScript"],
		project_url: "https://github.com/mykxttyjay/my_portfolio"
	},
	{
		title: "Mobile App Design",
		description: "UI/UX design for a mobile application focused on user experience and modern design principles.",
		icon: "fa-solid fa-mobile-screen",
		tags: ["UI/UX", "Figma", "Design"],
		project_url: ""
	},
	{
		title: "Web Application",
		description: "Full-stack web application with user authentication, data visualization, and real-time updates.",
		icon: "fa-solid fa-code",
		tags: ["React", "Node.js", "MongoDB"],
		project_url: ""
	}
];

try {
	const { entries } = await getEmDashCollection('projects');
	if (entries && entries.length > 0) {
		projectsList = entries.map((entry) => {
			const title = (entry.data?.title as string) || "";
			const description = (entry.data?.description as string) || "";
			const icon = (entry.data?.icon as string) || "";
			const tags_str = (entry.data?.tags as string) || "";
			const tags = tags_str ? tags_str.split(',').map((t: string) => t.trim()) : [];
			const project_url = (entry.data?.project_url as string) || "";
			return { title, description, icon, tags, project_url };
		});
	}
} catch (e) {
	console.error('Error fetching projects from EmDash:', e);
}
---

<section class="projects" id="projects">
	<h2 class="heading">My <span>Projects</span></h2>
	<div class="projects-container">
		{projectsList.map((project) => {
			const isLink = !!project.project_url;
			return isLink ? (
				<a href={project.project_url} target="_blank" class="project-card link-card">
					<div class="project-icon">
						<i class={project.icon}></i>
					</div>
					<h3>{project.title}</h3>
					<p>{project.description}</p>
					<div class="project-tags">
						{project.tags.map((tag) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				</a>
			) : (
				<div class="project-card">
					<div class="project-icon">
						<i class={project.icon}></i>
					</div>
					<h3>{project.title}</h3>
					<p>{project.description}</p>
					<div class="project-tags">
						{project.tags.map((tag) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				</div>
			);
		})}
	</div>
</section>

<style>
	.projects {
		background: #FEF9E1;
		padding: 5rem 0;
		position: relative;
		overflow: hidden;
	}

	.projects::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			url("data:image/svg+xml,%3Csvg viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' result='noise' seed='2' /%3E%3CfeColorMatrix in='noise' type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100' height='100' fill='%23000000' filter='url(%23noiseFilter)' opacity='0.08'/%3E%3C/svg%3E");
		background-size: 100px 100px;
		pointer-events: none;
		z-index: 0;
		mix-blend-mode: overlay;
	}

	.projects .heading {
		color: #A31D1D;
		position: relative;
		z-index: 1;
		font-family: 'Poppins', sans-serif;
		font-size: 60px;
		font-weight: 900;
		letter-spacing: 0px;
		font-style: italic;
	}

	.projects .heading span {
		-webkit-text-fill-color: #A31D1D;
		color: #A31D1D;
	}

	.projects-container {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2.5rem;
		position: relative;
		z-index: 1;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.project-card {
		background: rgba(255, 255, 255, 0.08);
		backdrop-filter: blur(12px);
		border: 1px solid rgba(255, 255, 255, 0.15);
		padding: 2.5rem 2rem;
		border-radius: 24px;
		box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1), 0 0 0 1px rgba(255, 255, 255, 0.05) inset;
		transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), border-color 0.4s ease, box-shadow 0.4s ease;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		text-decoration: none;
	}

	.project-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(255, 255, 255, 0.1) inset;
		border-color: rgba(255, 255, 255, 0.3);
	}

	.project-icon {
		width: 60px;
		height: 60px;
		background: rgba(255, 255, 255, 0.15);
		border-radius: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--white);
		font-size: 1.5rem;
		margin-bottom: 1.5rem;
		border: 1px solid rgba(255, 255, 255, 0.2);
		transition: transform 0.3s ease, border-radius 0.3s ease, background 0.3s ease;
	}

	.project-card:hover .project-icon {
		transform: scale(1.1) rotate(-8deg);
		border-radius: 50%;
		background: var(--white);
		color: var(--primary);
	}

	.project-card h3 {
		font-size: 1.45rem;
		color: var(--white);
		margin-bottom: 1rem;
		font-weight: 700;
	}

	.project-card p {
		color: rgba(255, 255, 255, 0.85);
		line-height: 1.7;
		margin-bottom: 1.5rem;
		font-size: 0.95rem;
	}

	.project-tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		margin-top: auto; /* Push tags to the bottom of the card */
	}

	.tag {
		padding: 0.4rem 0.9rem;
		background: rgba(255, 255, 255, 0.1);
		border: 1px solid rgba(255, 255, 255, 0.15);
		border-radius: 50px;
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--white);
		transition: all 0.3s ease;
		cursor: default;
	}

	.tag:hover {
		background: var(--white);
		color: var(--primary);
		transform: translateY(-2px);
		box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
	}
</style>
