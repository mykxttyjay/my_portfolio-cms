			/* Bottom-right corner */
			100% calc(100% - 4px), 100% 100%, calc(100% - 4px) 100%,
			/* Bottom edge - wavy */
			calc(100% - 8px) calc(100% - 4px), calc(100% - 12px) 100%, calc(100% - 16px) calc(100% - 4px), calc(100% - 20px) 100%, calc(100% - 24px) calc(100% - 4px), calc(100% - 28px) 100%, calc(100% - 32px) calc(100% - 4px), calc(100% - 36px) 100%, calc(100% - 40px) calc(100% - 4px), calc(100% - 44px) 100%, calc(100% - 48px) calc(100% - 4px), calc(100% - 52px) 100%, calc(100% - 56px) calc(100% - 4px), calc(100% - 60px) 100%, calc(100% - 64px) calc(100% - 4px), calc(100% - 68px) 100%, calc(100% - 72px) calc(100% - 4px), calc(100% - 76px) 100%, calc(100% - 80px) calc(100% - 4px), calc(100% - 84px) 100%, calc(100% - 88px) calc(100% - 4px), calc(100% - 92px) 100%, calc(100% - 96px) calc(100% - 4px), calc(100% - 100px) 100%, calc(100% - 104px) calc(100% - 4px), calc(100% - 108px) 100%, calc(100% - 112px) calc(100% - 4px), calc(100% - 116px) 100%, calc(100% - 120px) calc(100% - 4px), calc(100% - 124px) 100%, calc(100% - 128px) calc(100% - 4px), calc(100% - 132px) 100%, calc(100% - 136px) calc(100% - 4px), calc(100% - 140px) 100%, calc(100% - 144px) calc(100% - 4px), calc(100% - 148px) 100%, calc(100% - 152px) calc(100% - 4px), calc(100% - 156px) 100%, calc(100% - 160px) calc(100% - 4px), calc(100% - 164px) 100%, calc(100% - 168px) calc(100% - 4px), calc(100% - 172px) 100%, calc(100% - 176px) calc(100% - 4px), calc(100% - 180px) 100%, calc(100% - 184px) calc(100% - 4px), calc(100% - 188px) 100%, calc(100% - 192px) calc(100% - 4px), calc(100% - 196px) 100%, calc(100% - 200px) calc(100% - 4px), calc(100% - 204px) 100%, calc(100% - 208px) calc(100% - 4px), calc(100% - 212px) 100%, calc(100% - 216px) calc(100% - 4px), calc(100% - 220px) 100%, calc(100% - 224px) calc(100% - 4px), calc(100% - 228px) 100%, calc(100% - 232px) calc(100% - 4px), calc(100% - 236px) 100%, calc(100% - 240px) calc(100% - 4px), calc(100% - 244px) 100%, calc(100% - 248px) calc(100% - 4px), calc(100% - 252px) 100%, calc(100% - 256px) calc(100% - 4px), calc(100% - 260px) 100%, calc(100% - 264px) calc(100% - 4px), 