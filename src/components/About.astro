---
import CloudIcon from '../assets/cloud.svg';
import { safeGetEmDashCollection } from '../utils/emdash-helper';

let name = "Angel Marie Sabido";
let intro = "Aspiring IT professional with a strong work ethic and passion for learning and growth in technology. Committed to developing technical skills and contributing positively to team environments. Eager to gain hands-on experience and continuously improve to deliver quality results.";
let paragraph2 = "Throughout my academic journey, I've developed a solid foundation in various IT disciplines, from web development to database management. I'm particularly passionate about creating user-friendly digital solutions that solve real-world problems. My hands-on experience in different projects has taught me the importance of collaboration, attention to detail, and continuous learning in the ever-evolving tech landscape.";
let paragraph3 = "Driven by curiosity and a desire to make an impact, I aim to leverage my skills to support organizational goals, create innovative digital solutions, and grow as a well-rounded IT professional. I'm excited about the opportunities ahead and committed to bringing dedication and enthusiasm to every project I undertake.";
let resumeLink = "https://linkedin.com/in/gelmarie";

const { entries } = await safeGetEmDashCollection('profile');
if (entries && entries.length > 0 && entries[0].data) {
	name = (entries[0].data.name as string) || name;
	intro = (entries[0].data.intro as string) || intro;
	resumeLink = (entries[0].data.resume_link as string) || resumeLink;
}
---

<section class="about" id="about">
	<div class="about-container">
		<div class="about-card">
			<div class="card-image">
				<img src="https://images.unsplash.com/photo-1567484072688-2041f76a3fda?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Angel Marie Sabido" />
			</div>
			<div class="card-content">
				<h3 class="card-name">Hi! It's {name}</h3>
				<div class="card-info">
					<div class="info-row">
						<span class="label">Birthday:</span>
						<span class="value">September 30, 2003</span>
					</div>
					<div class="info-row">
						<span class="label">Degree:</span>
						<span class="value">Bachelor of Science in Information Technology</span>
					</div>
					<div class="info-row">
						<span class="label">Location:</span>
						<span class="value">Lapu-Lapu City Cebu, Philippines</span>
					</div>
					<div class="info-row">
						<span class="label">Email:</span>
						<span class="value">sabidoangel.uc@gmail.com</span>
					</div>
					<div class="info-row">
						<span class="label">Phone:</span>
						<span class="value">+63 954 291 7099</span>
					</div>
					<div class="info-row">
						<span class="label">Languages:</span>
						<span class="value">English, Filipino</span>
					</div>
				</div>
			</div>
		</div>

		<div class="about-content">
			<h2 class="about-title">About Me</h2>
			<p class="about-text">
				{intro}
			</p>
			<p class="about-text">
				{paragraph2}
			</p>
			<p class="about-text">
				{paragraph3}
			</p>
		</div>
	</div>

	<div class="clouds">
		<CloudIcon class="cloud-style cloud-1" />
		<CloudIcon class="cloud-style cloud-2" />
		<CloudIcon class="cloud-style cloud-3" />
	</div>
</section>

<script>
	function matchCardHeights() {
		const aboutCard = document.querySelector('.about-card') as HTMLElement;
		const aboutContainer = document.querySelector('.about-container') as HTMLElement;
		
		if (aboutCard && aboutContainer) {
			const cardHeight = aboutCard.offsetHeight;
			aboutContainer.style.setProperty('--card-height', `${cardHeight}px`);
		}
	}

	// Run on load
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', matchCardHeights);
	} else {
		matchCardHeights();
	}

	// Run on resize
	window.addEventListener('resize', matchCardHeights);
</script>

<style>
	.about {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 5rem 8%;
		position: relative;
		background-color: #FEF9E1;
		overflow: hidden;
	}

	.about::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			url("data:image/svg+xml,%3Csvg viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' result='noise' seed='2' /%3E%3CfeColorMatrix in='noise' type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100' height='100' fill='%23000000' filter='url(%23noiseFilter)' opacity='0.08'/%3E%3C/svg%3E");
		background-size: 100px 100px;
		pointer-events: none;
		z-index: 0;
		mix-blend-mode: overlay;
	}

	.about::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			url("data:image/svg+xml,%3Csvg viewBox='0 0 150 150' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise2'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='5' result='noise' seed='1' /%3E%3CfeColorMatrix in='noise' type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='150' height='150' fill='%23000000' filter='url(%23noise2)' opacity='0.06'/%3E%3C/svg%3E");
		background-size: 150px 150px;
		pointer-events: none;
		z-index: 1;
		mix-blend-mode: multiply;
	}

	.about-container {
		display: flex;
		gap: 6rem;
		align-items: flex-start;
		max-width: 1400px;
		width: 100%;
		z-index: 2;
		position: relative;
	}

	.about-container::before {
		content: '';
		position: absolute;
		top: 15px;
		left: 15px;
		width: 550px;
		height: 92%;
		background: #A31D1D;
		border-radius: 15px;
		transform: rotate(-7deg);
		z-index: 0;
	}

	.about-card {
		flex: 0 0 550px;
		background: white;
		border-radius: 15px;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
		overflow: hidden;
		animation: slideInLeft 0.8s ease-out;
		position: relative;
		transform: rotate(0deg);
		z-index: 1;
	}

	@keyframes slideInLeft {
		from {
			opacity: 0;
			transform: translateX(-50px) rotate(0deg);
		}
		to {
			opacity: 1;
			transform: translateX(0) rotate(0deg);
		}
	}

	.card-image {
		position: relative;
		width: 100%;
		height: 300px;
		overflow: hidden;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.card-seal {
		position: absolute;
		top: -40px;
		left: 50%;
		transform: translateX(-50%);
		width: 80px;
		height: 80px;
		background: linear-gradient(135deg, #A31D1D 0%, #8B1515 100%);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2rem;
		color: white;
		box-shadow: 0 10px 30px rgba(163, 29, 29, 0.4);
		border: 3px solid #FEF9E1;
		z-index: 10;
	}

	.card-content {
		padding: 2rem;
	}

	.card-name {
		font-size: 1.5625rem;
		font-weight: 700;
		color: #A31D1D;
		margin-bottom: 1.5rem;
		font-style: italic;
		padding-bottom: 1.5rem;
		border-bottom: 2px dashed #A31D1D;
	}

	.card-info {
		margin-bottom: 2rem;
		padding-bottom: 0;
	}

	.info-row {
		display: flex;
		justify-content: space-between;
		margin-bottom: 0.8rem;
		font-size: 0.95rem;
	}

	.info-row .label {
		font-weight: 700;
		color: #A31D1D;
	}

	.info-row .value {
		color: #A31D1D;
		font-weight: 500;
	}

.about-content {
		flex: 1;
		animation: slideInRight 0.8s ease-out;
	}

	@keyframes slideInRight {
		from {
			opacity: 0;
			transform: translateX(50px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	.about-title {
		font-size: 60px;
		font-weight: 900;
		color: #A31D1D;
		margin-bottom: 2rem;
		font-family: 'Poppins', sans-serif;
		letter-spacing: 0px;
		font-style: italic;
	}

	.about-text {
		font-size: 20px;
		line-height: 1.9;
		color: #5a3a5a;
		margin-bottom: 1.5rem;
		font-weight: 500;
	}

	.about-closing {
		font-size: 1.3rem;
		line-height: 1.8;
		color: #5a3a5a;
		margin-top: 2.5rem;
		margin-bottom: 2rem;
		font-style: italic;
		font-weight: 600;
	}

	.resume-link {
		display: inline-flex;
		align-items: center;
		gap: 0.8rem;
		color: #A31D1D;
		text-decoration: none;
		font-weight: 700;
		font-size: 1.1rem;
		transition: all 0.3s ease;
		padding: 0.5rem 1rem;
		border-radius: 50px;
	}

	.resume-link:hover {
		transform: translateX(10px);
		color: #8B1515;
	}

	.resume-link i {
		font-size: 0.9rem;
	}

	.clouds {
		position: absolute;
		bottom: -80px;
		left: 0;
		right: 0;
		height: 120px;
		z-index: 0;
		pointer-events: none;
		width: 100%;
		overflow: hidden;
	}

	.cloud-style {
		position: absolute;
		bottom: 0;
		width: 100px;
		height: auto;
		fill: rgba(255, 255, 255, 0.1);
		opacity: 0.5;
	}

	.cloud-1 {
		left: 5%;
		animation: moveClouds 60s linear infinite;
	}

	.cloud-2 {
		left: 35%;
		animation: moveClouds 80s linear infinite reverse;
		width: 120px;
	}

	.cloud-3 {
		left: 65%;
		animation: moveClouds 100s linear infinite;
		width: 90px;
	}

	@keyframes moveClouds {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(100vw);
		}
	}

	@media (max-width: 1024px) {
		.about-container {
			gap: 2rem;
		}

		.about-card {
			flex: 0 0 320px;
		}

		.about-title {
			font-size: 2.8rem;
		}

		.about-text {
			font-size: 1rem;
		}
	}

	@media (max-width: 768px) {
		.about {
			padding: 3rem 5%;
		}

		.about-container {
			flex-direction: column;
			gap: 2rem;
		}

		.about-card {
			flex: 1;
			width: 100%;
			max-width: 400px;
			margin: 0 auto;
			transform: rotate(0deg);
		}

		@keyframes slideInLeft {
			from {
				opacity: 0;
				transform: translateY(-30px) rotate(0deg);
			}
			to {
				opacity: 1;
				transform: translateY(0) rotate(0deg);
			}
		}

		.about-content {
			text-align: center;
		}

		.about-title {
			font-size: 2rem;
		}

		.about-text {
			font-size: 0.95rem;
		}

		.about-closing {
			font-size: 1.1rem;
		}

		.resume-link {
			justify-content: center;
		}
	}

	@media (max-width: 480px) {
		.about {
			padding: 2rem 4%;
		}

		.card-image {
			height: 250px;
		}

		.card-content {
			padding: 1.5rem;
		}

		.card-name {
			font-size: 1.2rem;
		}

		.about-title {
			font-size: 1.8rem;
		}

		.about-text {
			font-size: 0.9rem;
			line-height: 1.7;
		}
	}
</style>
