---
import CloudIcon from '../assets/cloud.svg';
import { safeGetEmDashCollection } from '../utils/emdash-helper';

let name = "Angel Marie Sabido";
let intro = "Hello! I am an aspiring IT professional with a strong work ethic and a deep passion for learning and growing in the technology space. Throughout my academic journey, I've built a solid foundation in various IT disciplines, from web development to database management. I am particularly passionate about creating user-friendly digital solutions that solve real-world problems, always eager to gain hands-on experience and continuously improve my craft.";
let paragraph2 = "My hands-on experience across different projects has taught me the importance of collaboration, attention to detail, and continuous learning in our ever-evolving tech landscape. Driven by curiosity and a desire to make a meaningful impact, I aim to leverage my skills to support organizational goals and create innovative solutions. I am incredibly excited about the opportunities ahead and remain committed to bringing dedication and enthusiasm to every project I undertake.";
let resumeLink = "https://linkedin.com/in/gelmarie";

const { entries } = await safeGetEmDashCollection('profile');
if (entries && entries.length > 0 && entries[0].data) {
	name = (entries[0].data.name as string) || name;
	intro = (entries[0].data.intro as string) || intro;
	resumeLink = (entries[0].data.resume_link as string) || resumeLink;
}

const currentDate = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<section class="about" id="about">
	<div class="about-container">
		<div class="about-card-wrapper">
			<div class="about-card">
				<div class="card-image">
					<img src="https://images.unsplash.com/photo-1567484072688-2041f76a3fda?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Angel Marie Sabido" />
				</div>
				<div class="card-content">
					<h3 class="card-name">Hi! It's {name}</h3>
					<div class="card-info">
						<div class="info-row">
							<span class="label">Birthday:</span>
							<span class="value">September 30, 2003</span>
						</div>
						<div class="info-row">
							<span class="label">Degree:</span>
							<span class="value">Bachelor of Science in Information Technology</span>
						</div>
						<div class="info-row">
							<span class="label">Location:</span>
							<span class="value">Lapu-Lapu City Cebu, Philippines</span>
						</div>
						<div class="info-row">
							<span class="label">Email:</span>
							<span class="value">sabidoangel.uc@gmail.com</span>
						</div>
						<div class="info-row">
							<span class="label">Phone:</span>
							<span class="value">+63 954 291 7099</span>
						</div>
						<div class="info-row">
							<span class="label">Languages:</span>
							<span class="value">English, Filipino</span>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="about-content">
			<div class="about-letter">
				<p class="letter-greeting">About Me</p>
				<div class="letter-body">
					<p class="about-text">
						{intro}
					</p>
					<p class="about-text">
						{paragraph2}
					</p>
				</div>
				<div class="letter-footer">
					<p class="letter-closing">Warmly,</p>
					<p class="letter-signature">{name}</p>
				</div>
			</div>
		</div>
	</div>

	<div class="clouds">
		<CloudIcon class="cloud-style cloud-1" />
		<CloudIcon class="cloud-style cloud-2" />
		<CloudIcon class="cloud-style cloud-3" />
	</div>
</section>

<style>
	.about {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 5rem 8%;
		position: relative;
		background-color: #FEF9E1;
		overflow: hidden;
	}

	.about::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			url("data:image/svg+xml,%3Csvg viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' result='noise' seed='2' /%3E%3CfeColorMatrix in='noise' type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100' height='100' fill='%23000000' filter='url(%23noiseFilter)' opacity='0.08'/%3E%3C/svg%3E");
		background-size: 100px 100px;
		pointer-events: none;
		z-index: 0;
		mix-blend-mode: overlay;
	}

	.about::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			url("data:image/svg+xml,%3Csvg viewBox='0 0 150 150' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise2'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='5' result='noise' seed='1' /%3E%3CfeColorMatrix in='noise' type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='150' height='150' fill='%23000000' filter='url(%23noise2)' opacity='0.06'/%3E%3C/svg%3E");
		background-size: 150px 150px;
		pointer-events: none;
		z-index: 1;
		mix-blend-mode: multiply;
	}

	.about-container {
		display: flex;
		gap: 6rem;
		align-items: flex-start;
		max-width: 1400px;
		width: 100%;
		z-index: 2;
		position: relative;
	}

	.about-card-wrapper {
		flex: 0 0 550px;
		position: relative;
		z-index: 1;
		animation: slideInLeft 0.8s ease-out;
	}

	.about-card-wrapper::before {
		content: '';
		position: absolute;
		top: 15px;
		left: 15px;
		width: 100%;
		height: 100%;
		background: #A31D1D;
		border-radius: 15px;
		transform: rotate(-7deg);
		z-index: 0;
	}

	.about-card {
		background: white;
		border-radius: 15px;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
		overflow: hidden;
		position: relative;
		z-index: 1;
		border: 1px solid rgba(163, 29, 29, 0.08);
	}

	@keyframes slideInLeft {
		from {
			opacity: 0;
			transform: translateX(-50px) rotate(0deg);
		}
		to {
			opacity: 1;
			transform: translateX(0) rotate(0deg);
		}
	}

	.card-image {
		position: relative;
		width: 100%;
		height: 300px;
		overflow: hidden;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
	}

	.about-card:hover .card-image img {
		transform: scale(1.05);
	}

	.card-seal {
		position: absolute;
		top: -40px;
		left: 50%;
		transform: translateX(-50%);
		width: 80px;
		height: 80px;
		background: linear-gradient(135deg, #A31D1D 0%, #8B1515 100%);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2rem;
		color: white;
		box-shadow: 0 10px 30px rgba(163, 29, 29, 0.4);
		border: 3px solid #FEF9E1;
		z-index: 10;
	}

	.card-content {
		padding: 2rem;
	}

	.card-name {
		font-family: 'Playfair Display', Georgia, serif;
		font-size: 1.6rem;
		font-weight: 700;
		color: #A31D1D;
		margin-bottom: 1.5rem;
		font-style: italic;
		padding-bottom: 1.5rem;
		border-bottom: 2px dashed rgba(163, 29, 29, 0.15);
	}

	.card-info {
		margin-bottom: 1.5rem;
		padding-bottom: 0;
	}

	.info-row {
		display: flex;
		align-items: baseline;
		margin-bottom: 1.1rem;
		font-size: 0.95rem;
		gap: 0.5rem;
	}

	.info-row .label {
		font-weight: 700;
		color: #A31D1D;
		flex-shrink: 0;
	}

	.info-row::after {
		content: '';
		flex-grow: 1;
		border-bottom: 1px dotted rgba(163, 29, 29, 0.25);
		margin: 0 0.2rem;
		align-self: flex-end;
		margin-bottom: 0.25rem;
	}

	.info-row .value {
		color: #A31D1D;
		font-weight: 600;
		text-align: right;
		flex-shrink: 1;
	}

.about-content {
		flex: 1;
		animation: slideInRight 0.8s ease-out;
	}

	@keyframes slideInRight {
		from {
			opacity: 0;
			transform: translateX(50px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	.about-title {
		font-size: 3.5rem;
		font-weight: 700;
		color: #A31D1D;
		margin-bottom: 0.5rem;
		font-family: 'Playfair Display', Georgia, serif;
		letter-spacing: 1px;
		font-style: italic;
		text-shadow: 2px 2px 4px rgba(163, 29, 29, 0.1);
	}

	.about-letter {
		margin-top: -2rem;
		background: #FFFDF8;
		padding: 2rem 4rem 3.5rem 4rem;
		border-radius: 16px;
		box-shadow: 
			0 20px 50px rgba(0, 0, 0, 0.04), 
			0 4px 15px rgba(163, 29, 29, 0.02),
			inset 0 0 40px rgba(163, 29, 29, 0.01);
		border: 1px solid rgba(163, 29, 29, 0.08);
		position: relative;
		overflow: hidden;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.about-letter:hover {
		transform: translateY(-2px);
		box-shadow: 
			0 25px 60px rgba(0, 0, 0, 0.06), 
			0 6px 20px rgba(163, 29, 29, 0.03);
	}

	.about-letter::before {
		content: '';
		position: absolute;
		top: 0;
		bottom: 0;
		left: 2.5rem;
		width: 1px;
		background: rgba(163, 29, 29, 0.15);
		pointer-events: none;
	}

	.about-letter::after {
		content: '✉';
		position: absolute;
		bottom: 1.5rem;
		right: 2rem;
		font-size: 6rem;
		color: rgba(163, 29, 29, 0.025);
		font-family: serif;
		pointer-events: none;
		transform: rotate(-10deg);
	}

	.letter-greeting {
		font-family: 'Dancing Script', cursive;
		font-size: 50px;
		color: #A31D1D;
		margin-top: 0;
		margin-bottom: 1.8rem;
		padding-left: 1.5rem;
		font-weight: 700;
		line-height: 1.2;
	}

	.letter-body {
		padding-left: 1.5rem;
		margin-bottom: 2.5rem;
	}

	.about-text {
		font-size: 1.15rem;
		line-height: 1.9;
		color: #5a3a5a;
		margin-bottom: 1.5rem;
		font-weight: 500;
		text-align: justify;
		text-indent: 2rem;
	}

	.about-text:last-child {
		margin-bottom: 0;
	}

	.letter-footer {
		padding-left: 1.5rem;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		margin-top: 2rem;
		border-top: 1px dashed rgba(163, 29, 29, 0.1);
		padding-top: 1.5rem;
	}

	.letter-closing {
		font-family: 'Dancing Script', cursive;
		font-size: 1.6rem;
		color: #A31D1D;
		margin-bottom: 0.2rem;
		font-weight: 600;
	}

	.letter-signature {
		font-family: 'Dancing Script', cursive;
		font-size: 2.6rem;
		color: #A31D1D;
		font-weight: 700;
		line-height: 1;
		transform: rotate(-3deg);
		margin-right: 1.5rem;
		text-shadow: 1px 1px 2px rgba(163, 29, 29, 0.15);
	}

	.resume-link {
		display: inline-flex;
		align-items: center;
		gap: 0.8rem;
		color: #A31D1D;
		text-decoration: none;
		font-weight: 700;
		font-size: 1.1rem;
		transition: all 0.3s ease;
		padding: 0.5rem 1rem;
		border-radius: 50px;
	}

	.resume-link:hover {
		transform: translateX(10px);
		color: #8B1515;
	}

	.resume-link i {
		font-size: 0.9rem;
	}

	.clouds {
		position: absolute;
		bottom: -80px;
		left: 0;
		right: 0;
		height: 120px;
		z-index: 0;
		pointer-events: none;
		width: 100%;
		overflow: hidden;
	}

	.cloud-style {
		position: absolute;
		bottom: 0;
		width: 100px;
		height: auto;
		fill: rgba(255, 255, 255, 0.1);
		opacity: 0.5;
	}

	.cloud-1 {
		left: 5%;
		animation: moveClouds 60s linear infinite;
	}

	.cloud-2 {
		left: 35%;
		animation: moveClouds 80s linear infinite reverse;
		width: 120px;
	}

	.cloud-3 {
		left: 65%;
		animation: moveClouds 100s linear infinite;
		width: 90px;
	}

	@keyframes moveClouds {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(100vw);
		}
	}

	@media (max-width: 1024px) {
		.about-container {
			gap: 2rem;
		}

		.about-card-wrapper {
			flex: 0 0 320px;
		}

		.about-title {
			font-size: 2.8rem;
		}

		.about-text {
			font-size: 1rem;
		}
	}

	@media (max-width: 768px) {
		.about {
			padding: 3rem 5%;
		}

		.about-container {
			flex-direction: column;
			gap: 2rem;
		}

		.about-card-wrapper {
			flex: 1;
			width: 100%;
			max-width: 400px;
			margin: 0 auto;
		}

		.about-card-wrapper::before {
			transform: rotate(-4deg);
		}

		@keyframes slideInLeft {
			from {
				opacity: 0;
				transform: translateY(-30px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.about-content {
			text-align: center;
		}

		.about-title {
			font-size: 2rem;
		}

		.about-letter {
			text-align: left;
			padding: 2rem 3rem;
		}

		.about-text {
			font-size: 1rem;
		}

		.resume-link {
			justify-content: center;
		}
	}

	@media (max-width: 480px) {
		.about {
			padding: 2rem 4%;
		}

		.card-image {
			height: 250px;
		}

		.card-content {
			padding: 1.5rem;
		}

		.card-name {
			font-size: 1.2rem;
		}

		.about-title {
			font-size: 1.8rem;
		}

		.about-letter {
			padding: 1.5rem 1.8rem;
		}

		.about-letter::before {
			left: 1.2rem;
		}

		.letter-header, .letter-greeting, .letter-body, .letter-footer {
			padding-left: 0.5rem;
		}

		.about-text {
			text-indent: 1.5rem;
			font-size: 0.95rem;
			line-height: 1.8;
		}

		.letter-signature {
			font-size: 2.2rem;
		}

		.letter-greeting {
			font-size: 2.1rem;
			margin-bottom: 1.2rem;
		}
	}
</style>
