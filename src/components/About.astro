---
import profileData from '../data/profile.json'

const { firstName, lastName, birthday, degree, location, email, specialization, aboutParagraph1, aboutParagraph2 } = profileData
const fullName = `${firstName} ${lastName}`
---

<section class="about" id="about">
	<!-- Sparkles matching Home section -->
	<div class="sparkles-container">
		<div class="sparkle sparkle-1">
			<svg viewBox="0 0 24 24"><path d="M12,2 L15,9 L22,12 L15,15 L12,22 L9,15 L2,12 L9,9 Z" /></svg>
		</div>
		<div class="sparkle sparkle-2">
			<svg viewBox="0 0 24 24"><path d="M12,2 L14,10 L22,12 L14,14 L12,22 L10,14 L2,12 L10,10 Z" /></svg>
		</div>
		<div class="sparkle sparkle-3">
			<svg viewBox="0 0 24 24"><path d="M12,2 L15,9 L22,12 L15,15 L12,22 L9,15 L2,12 L9,9 Z" /></svg>
		</div>
		<div class="sparkle sparkle-4">
			<svg viewBox="0 0 24 24"><path d="M12,2 L14,10 L22,12 L14,14 L12,22 L10,14 L2,12 L10,10 Z" /></svg>
		</div>
	</div>

	<div class="about-container">
		<div class="combined-about-card">
			<!-- Profile Section -->
			<div class="profile-section">
				<div class="card-image">
					<img src="/profile.jpg" alt={fullName} />
				</div>
				<div class="card-content">
					<h3 class="card-name">Hi! It's {fullName}</h3>
					<div class="card-info">
						<div class="info-row">
							<span class="label">Birthday:</span>
							<span class="value">{birthday}</span>
						</div>
						<div class="info-row">
							<span class="label">Degree:</span>
							<span class="value">{degree}</span>
						</div>
						<div class="info-row">
							<span class="label">Location:</span>
							<span class="value">{location}</span>
						</div>
						<div class="info-row">
							<span class="label">Email:</span>
							<span class="value">{email}</span>
						</div>
						<div class="info-row">
							<span class="label">Specialization:</span>
							<span class="value">{specialization}</span>
						</div>
					</div>
				</div>
			</div>

			<!-- Letter Section -->
			<div class="letter-section">
				<p class="letter-greeting">About Me</p>
				<div class="letter-body">
					<p class="about-text">
						{aboutParagraph1}
					</p>
					<p class="about-text">
						{aboutParagraph2}
					</p>
				</div>
				<div class="letter-footer">
					<p class="letter-closing">Warmly,</p>
					<p class="letter-signature">{fullName}</p>
				</div>
			</div>
		</div>
	</div>

	<div class="clouds">
		<svg class="cloud-style cloud-1" viewBox="0 0 100 50" xmlns="http://www.w3.org/2000/svg">
			<path d="M20,30 Q20,15 35,15 Q40,5 50,5 Q65,5 70,20 Q85,20 85,30 Z" fill="currentColor"/>
		</svg>
		<svg class="cloud-style cloud-2" viewBox="0 0 100 50" xmlns="http://www.w3.org/2000/svg">
			<path d="M20,30 Q20,15 35,15 Q40,5 50,5 Q65,5 70,20 Q85,20 85,30 Z" fill="currentColor"/>
		</svg>
		<svg class="cloud-style cloud-3" viewBox="0 0 100 50" xmlns="http://www.w3.org/2000/svg">
			<path d="M20,30 Q20,15 35,15 Q40,5 50,5 Q65,5 70,20 Q85,20 85,30 Z" fill="currentColor"/>
		</svg>
	</div>
</section>

<script>
	const initScrollConnect = () => {
		const aboutSection = document.querySelector('.about');
		const combinedCard = document.querySelector('.combined-about-card');
		
		if (!aboutSection || !combinedCard) return;

		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.target === aboutSection) {
					if (entry.isIntersecting) {
						combinedCard.classList.add('scroll-active');
					} else {
						combinedCard.classList.remove('scroll-active');
					}
				}
			});
		}, { threshold: 0.2 });

		observer.observe(aboutSection);
	};

	initScrollConnect();
	document.addEventListener('astro:page-load', initScrollConnect);
</script>

<style>
	.about {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0 8% 5rem 8%;
		position: relative;
		background-color: #8F1D21;
		overflow: hidden;
	}

	.about::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			url("data:image/svg+xml,%3Csvg viewBox='0 0 150 150' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.03' numOctaves='4' result='noise' seed='1' /%3E%3CfeColorMatrix in='noise' type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' fill='%23000000' filter='url(%23noiseFilter)' opacity='0.12'/%3E%3C/svg%3E");
		background-size: 150px 150px;
		pointer-events: none;
		z-index: 2;
		mix-blend-mode: overlay;
	}

	.about::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: radial-gradient(circle at 50% 50%, rgba(155, 30, 34, 0.4) 0%, rgba(90, 14, 17, 0.85) 100%);
		pointer-events: none;
		z-index: 1;
	}

	.sparkles-container {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 12;
		overflow: hidden;
	}

	.sparkle {
		position: absolute;
		opacity: 0.85;
		color: #FFF2D4;
		filter: drop-shadow(0 0 8px rgba(255, 242, 212, 0.8));
		pointer-events: none;
		transform-origin: center;
	}

	.sparkle svg {
		width: 100%;
		height: 100%;
		fill: currentColor;
		display: block;
		transform-origin: center;
	}

	.sparkle-1 {
		top: 15%;
		left: 10%;
		width: 28px;
		height: 28px;
		animation: twinkle-1 4s ease-in-out infinite;
	}

	.sparkle-2 {
		top: 25%;
		right: 12%;
		width: 22px;
		height: 22px;
		animation: twinkle-2 3.5s ease-in-out infinite;
	}

	.sparkle-3 {
		top: 70%;
		left: 8%;
		width: 24px;
		height: 24px;
		animation: twinkle-1 3.8s ease-in-out infinite;
	}

	.sparkle-4 {
		top: 75%;
		right: 15%;
		width: 20px;
		height: 20px;
		animation: twinkle-2 4.2s ease-in-out infinite;
	}

	@keyframes twinkle-1 {
		0%, 100% {
			transform: scale(0.6) translateY(0) rotate(0deg);
			opacity: 0.4;
		}
		50% {
			transform: scale(1.1) translateY(-15px) rotate(180deg);
			opacity: 1;
		}
	}

	@keyframes twinkle-2 {
		0%, 100% {
			transform: scale(0.8) translateY(0) rotate(0deg);
			opacity: 0.5;
		}
		50% {
			transform: scale(1.2) translateY(-25px) rotate(-90deg);
			opacity: 1;
		}
	}

	.about-container {
		display: flex;
		justify-content: center;
		align-items: center;
		width: 100%;
		z-index: 2;
		position: relative;
	}

	.combined-about-card {
		width: 1100px;
		max-width: 95%;
		display: grid;
		grid-template-columns: 1.05fr 1.20fr;
		gap: 0;
		background: #FCF8F2;
		border: 3.5px solid #4A1215;
		border-radius: 16px;
		box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
		overflow: hidden;
		transform: translateY(-60px);
		opacity: 0;
		transition: all 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
		position: relative;
		z-index: 10;
	}

	.combined-about-card::after {
		content: none;
	}

	.combined-about-card.scroll-active {
		transform: translateY(0);
		opacity: 1;
	}

	.profile-section {
		display: flex;
		flex-direction: column;
		background: #FFFDF8;
		padding: 3rem 1.5rem 2rem 1.5rem;
	}

	.letter-section {
		background: #FFFDF8;
		padding: 3rem 3rem 3.5rem 3rem;
		position: relative;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
	}

	.card-image {
		position: relative;
		width: 100%;
		height: 280px;
		overflow: visible;
		margin-bottom: 2rem;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0 0.5rem;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
		border: 2.5px solid #4A1215;
		border-radius: 0;
		box-shadow: none;
		position: relative;
	}

	.card-image::before {
		content: '';
		position: absolute;
		inset: -8px;
		background: #FFFEF8;
		z-index: -1;
		clip-path: polygon(
			/* Top edge - wavy */
			0% 4px, 4px 0%, 8px 4px, 12px 0%, 16px 4px, 20px 0%, 24px 4px, 28px 0%, 32px 4px, 36px 0%, 40px 4px, 44px 0%, 48px 4px, 52px 0%, 56px 4px, 60px 0%, 64px 4px, 68px 0%, 72px 4px, 76px 0%, 80px 4px, 84px 0%, 88px 4px, 92px 0%, 96px 4px, 100px 0%, 104px 4px, 108px 0%, 112px 4px, 116px 0%, 120px 4px, 124px 0%, 128px 4px, 132px 0%, 136px 4px, 140px 0%, 144px 4px, 148px 0%, 152px 4px, 156px 0%, 160px 4px, 164px 0%, 168px 4px, 172px 0%, 176px 4px, 180px 0%, 184px 4px, 188px 0%, 192px 4px, 196px 0%, 200px 4px, 204px 0%, 208px 4px, 212px 0%, 216px 4px, 220px 0%, 224px 4px, 228px 0%, 232px 4px, 236px 0%, 240px 4px, 244px 0%, 248px 4px, 252px 0%, 256px 4px, 260px 0%, 264px 4px, 268px 0%, 272px 4px, 276px 0%, 280px 4px,
