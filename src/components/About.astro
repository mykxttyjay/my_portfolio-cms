<section class="about" id="about">
	<h2 class="heading">Educational <span>Background</span></h2>
	<div class="timeline">
		<div class="timeline-item">
			<div class="timeline-dot"></div>
			<div class="timeline-date">Batch 2026</div>
			<div class="timeline-content">
				<div class="timeline-connector"></div>
				<h3>Bachelor of Science in Information Technology</h3>
				<h4>University of Cebu - Lapu-Lapu and Mandaue</h4>
				<p>Dean's Lister from 1st Year to 3rd Year</p>
				<div class="achievement-badge">
					<i class="fa-solid fa-award"></i>
					<span>Dean's Lister</span>
				</div>
				<div class="achievement-badge">
					<i class="fa-solid fa-graduation-cap"></i>
					<span>Academic Scholar</span>
				</div>
			</div>
		</div>
		<div class="timeline-item">
			<div class="timeline-dot"></div>
			<div class="timeline-date">Batch 2022</div>
			<div class="timeline-content">
				<div class="timeline-connector"></div>
				<h3>Senior High School</h3>
				<h4>University of Cebu - Lapu-Lapu and Mandaue</h4>
				<p>Science, Technology, Engineering, and Mathematics (STEM)</p>
				<div class="achievement-badge">
					<i class="fa-solid fa-medal"></i>
					<span>With Honors</span>
				</div>
				<div class="achievement-badge">
					<i class="fa-solid fa-graduation-cap"></i>
					<span>Academic Scholar</span>
				</div>
			</div>
		</div>
		<div class="timeline-item">
			<div class="timeline-dot"></div>
			<div class="timeline-date">Class of 2020</div>
			<div class="timeline-content">
				<h3>Junior High School</h3>
				<h4>Babag National High School</h4>
				<p>Graduated with Honors</p>
				<div class="achievement-badge">
					<i class="fa-solid fa-medal"></i>
					<span>With Honors</span>
				</div>
			</div>
		</div>
		<div class="timeline-item">
			<div class="timeline-dot"></div>
			<div class="timeline-date">Class of 2016</div>
			<div class="timeline-content">
				<h3>Elementary</h3>
				<h4>Babag Elementary School</h4>
				<p>Completed primary education</p>
			</div>
		</div>
	</div>
</section>

<style>
	.about {
		background: #a288a6;
		padding: 5rem 0;
	}

	.about .heading {
		color: #ffffff;
	}

	.about .heading span {
		-webkit-text-fill-color: #ecdddf;
		color: #ecdddf;
	}

	.timeline {
		max-width: 900px;
		margin: 0 auto;
		padding: 0 2rem;
		position: relative;
	}

	.timeline::before {
		content: '';
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		width: 3px;
		height: 100%;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.3) 0%, rgba(255, 255, 255, 0.6) 50%, rgba(255, 255, 255, 0.3) 100%);
		border-radius: 2px;
	}

	.timeline-item {
		position: relative;
		margin-bottom: 3rem;
		display: flex;
		align-items: flex-start;
		gap: 2rem;
	}

	.timeline-item:nth-child(odd) {
		flex-direction: row;
	}

	.timeline-item:nth-child(even) {
		flex-direction: row-reverse;
	}

	.timeline-dot {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		width: 20px;
		height: 20px;
		background: var(--white);
		border: 4px solid #ecdddf;
		border-radius: 50%;
		z-index: 2;
		box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.2);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.timeline-item:hover .timeline-dot {
		transform: translateX(-50%) scale(1.3);
		box-shadow: 0 0 0 8px rgba(255, 255, 255, 0.3);
	}

	.timeline-date {
		flex: 0 0 150px;
		text-align: right;
		font-size: 1rem;
		font-weight: 700;
		color: #ffffff;
		padding-top: 0.5rem;
		letter-spacing: 1px;
	}

	.timeline-item:nth-child(even) .timeline-date {
		text-align: left;
	}

	.timeline-content {
		flex: 1;
		background: rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(12px);
		border: 1px solid rgba(255, 255, 255, 0.2);
		padding: 2rem;
		border-radius: 20px;
		box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1), 0 0 0 1px rgba(255, 255, 255, 0.05) inset;
		transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease, border-color 0.3s ease;
		position: relative;
	}

	.timeline-content:hover {
		transform: translateY(-5px);
		box-shadow: 0 20px 45px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(255, 255, 255, 0.1) inset;
		border-color: rgba(255, 255, 255, 0.3);
	}

	.timeline-connector {
		position: absolute;
		top: 30px;
		width: 30px;
		height: 2px;
		background: rgba(255, 255, 255, 0.3);
	}

	.timeline-item:nth-child(odd) .timeline-connector {
		left: -30px;
	}

	.timeline-item:nth-child(even) .timeline-connector {
		right: -30px;
	}

	.timeline-content h3 {
		font-size: 1.4rem;
		color: #ffffff;
		margin-bottom: 0.5rem;
		font-weight: 700;
	}

	.timeline-content h4 {
		font-size: 1.1rem;
		color: #ecdddf;
		margin-bottom: 0.75rem;
		font-weight: 600;
	}

	.timeline-content p {
		color: rgba(255, 255, 255, 0.9);
		line-height: 1.7;
		margin-bottom: 1rem;
		font-size: 0.95rem;
	}

	.achievement-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: rgba(255, 255, 255, 0.15);
		border: 1px solid rgba(255, 255, 255, 0.2);
		padding: 0.5rem 1rem;
		border-radius: 50px;
		font-size: 0.85rem;
		font-weight: 600;
		color: #ffffff;
		margin-right: 0.5rem;
		margin-top: 0.5rem;
		transition: all 0.3s ease;
	}

	.achievement-badge:hover {
		background: rgba(255, 255, 255, 0.25);
		transform: translateY(-2px);
		box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
	}

	.achievement-badge i {
		font-size: 1rem;
		color: #ecdddf;
	}

	@media (max-width: 768px) {
		.timeline::before {
			left: 20px;
		}

		.timeline-item {
			flex-direction: column !important;
			padding-left: 50px;
		}

		.timeline-item:nth-child(even) {
			flex-direction: column !important;
		}

		.timeline-dot {
			left: 20px;
		}

		.timeline-date {
			flex: none;
			text-align: left !important;
			margin-bottom: 0.5rem;
		}

		.timeline-connector {
			display: none;
		}

		.timeline-content {
			margin-left: 0;
		}
	}
</style>
