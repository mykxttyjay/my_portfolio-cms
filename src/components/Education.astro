---

<section class="education-social" id="education-social">
	<div class="education-social-container">
		<h2 class="section-title">Education</h2>
		
		<!-- Education Section -->
		<div class="education-section">
			<!-- College -->
			<div class="education-card">
				<div class="education-icon">
					<i class="fa-solid fa-graduation-cap"></i>
				</div>
				<div class="education-content">
					<h3 class="degree">Bachelor of Science in Information Technology</h3>
					<p class="school">University of Cebu - Lapu-Lapu and Mandaue</p>
					<p class="year">Batch 2026</p>
					<div class="achievements">
						<span class="achievement-badge">Dean's Lister (1st Year to 4th Year)</span>
						<span class="achievement-badge">Academic Scholar</span>
					</div>
				</div>
			</div>

			<!-- Senior High School -->
			<div class="education-card">
				<div class="education-icon">
					<i class="fa-solid fa-school"></i>
				</div>
				<div class="education-content">
					<h3 class="degree">Senior High School</h3>
					<p class="school">University of Cebu - Lapu-Lapu and Mandaue</p>
					<p class="year">Batch 2022</p>
					<p class="strand">Science, Technology, Engineering, and Mathematics (STEM)</p>
					<div class="achievements">
						<span class="achievement-badge">With Honors</span>
						<span class="achievement-badge">Academic Scholar</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Awards Section -->
		<div class="awards-section">
			<h2 class="section-title">Awards</h2>
			<div class="awards-grid">
				<!-- Award Card -->
				<div class="education-card">
					<div class="education-icon">
						<i class="fa-solid fa-trophy"></i>
					</div>
					<div class="education-content">
						<h3 class="degree">2nd Place - Poster Presentation</h3>
						<p class="school">UC CCS Research Congress 2026</p>
						<p class="year">May 13, 2026</p>
						<p class="description">
							Paper entitled "SecureDocs: An AI-Driven Document Management with Blockchain Integration and Advance Security for Effortless Access"
						</p>
					</div>
				</div>
			</div>
		</div>


	</div>
</section>

<style>
	.education-social {
		background-color: #F5F0E8;
		padding: 5rem 8%;
		position: relative;
		overflow: hidden;
	}

	.education-social::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='crumple'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.04' numOctaves='5' result='noise' seed='3' /%3E%3CfeDisplacementMap in='SourceGraphic' in2='noise' scale='8' xChannelSelector='R' yChannelSelector='G'/%3E%3C/filter%3E%3Crect width='200' height='200' fill='%23F5F0E8' filter='url(%23crumple)' opacity='0.4'/%3E%3C/svg%3E");
		background-size: 200px 200px;
		pointer-events: none;
		z-index: 0;
		mix-blend-mode: multiply;
	}

	.education-social-container {
		max-width: 1400px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}

	.section-title {
		font-size: 3.5rem;
		font-weight: 700;
		color: #A31D1D;
		margin-bottom: 3rem;
		font-family: 'Playfair Display', Georgia, serif;
		font-style: italic;
		text-align: center;
		letter-spacing: 1px;
		text-shadow: 2px 2px 4px rgba(163, 29, 29, 0.1);
	}

	/* Education Styles */
	.education-section {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
	}

	.education-card {
		background: white;
		padding: 2.5rem;
		border-radius: 20px;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
		display: flex;
		gap: 2rem;
		align-items: flex-start;
		transition: all 0.3s ease;
		border: 1px solid rgba(163, 29, 29, 0.08);
	}

	.education-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
		border-color: rgba(163, 29, 29, 0.15);
	}

	.education-icon {
		width: 70px;
		height: 70px;
		background: linear-gradient(135deg, #A31D1D 0%, #8B1515 100%);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		font-size: 1.8rem;
		flex-shrink: 0;
		box-shadow: 0 6px 20px rgba(163, 29, 29, 0.25);
	}

	.education-content {
		flex: 1;
	}

	.degree {
		font-size: 1.3rem;
		font-weight: 700;
		color: #A31D1D;
		margin-bottom: 0.8rem;
		line-height: 1.3;
	}

	.school {
		font-size: 1rem;
		font-weight: 600;
		color: #333;
		margin-bottom: 0.5rem;
		line-height: 1.4;
	}

	.year {
		font-size: 0.9rem;
		color: #A31D1D;
		font-weight: 700;
		margin-bottom: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.strand {
		font-size: 0.95rem;
		color: #555;
		margin-bottom: 1rem;
		line-height: 1.5;
	}

	.description {
		font-size: 0.95rem;
		line-height: 1.7;
		color: #555;
	}

	.achievements {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: 1rem;
	}

	.achievement-badge {
		background: #f5f0f0;
		border: 1px solid rgba(163, 29, 29, 0.2);
		padding: 0.4rem 0.9rem;
		border-radius: 50px;
		font-size: 0.8rem;
		font-weight: 600;
		color: #A31D1D;
		transition: all 0.3s ease;
	}

	.achievement-badge:hover {
		background: linear-gradient(135deg, #A31D1D 0%, #8B1515 100%);
		color: white;
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(163, 29, 29, 0.2);
	}

	/* Awards Styles */
	.awards-section {
		margin-top: 4rem;
	}

	.awards-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	@media (max-width: 768px) {
		.education-social {
			padding: 3rem 5%;
		}

		.section-title {
			font-size: 2rem;
		}

		.education-section {
			grid-template-columns: 1fr;
		}

		.education-card {
			flex-direction: column;
			text-align: center;
			align-items: center;
		}
	}

	@media (max-width: 480px) {
		.education-social {
			padding: 2rem 4%;
		}

		.section-title {
			font-size: 1.8rem;
		}

		.degree {
			font-size: 1.2rem;
		}
	}
</style>
