<section class="education" id="education">
	<h2 class="heading">Educational <span>Background</span></h2>
	<div class="timeline">
		<div class="timeline-item">
			<div class="timeline-dot"></div>
			<div class="timeline-date">Batch 2026</div>
			<div class="timeline-content">
				<div class="timeline-connector"></div>
				<h3>Bachelor of Science in Information Technology</h3>
				<h4>University of Cebu - Lapu-Lapu and Mandaue</h4>
				<p>Dean's Lister from 1st Year to 3rd Year</p>
				<div class="achievement-badge">
					<i class="fa-solid fa-award"></i>
					<span>Dean's Lister</span>
				</div>
				<div class="achievement-badge">
					<i class="fa-solid fa-graduation-cap"></i>
					<span>Academic Scholar</span>
				</div>
			</div>
		</div>
		<div class="timeline-item">
			<div class="timeline-dot"></div>
			<div class="timeline-date">Batch 2022</div>
			<div class="timeline-content">
				<div class="timeline-connector"></div>
				<h3>Senior High School</h3>
				<h4>University of Cebu - Lapu-Lapu and Mandaue</h4>
				<p>Science, Technology, Engineering, and Mathematics (STEM)</p>
				<div class="achievement-badge">
					<i class="fa-solid fa-medal"></i>
					<span>With Honors</span>
				</div>
				<div class="achievement-badge">
					<i class="fa-solid fa-graduation-cap"></i>
					<span>Academic Scholar</span>
				</div>
			</div>
		</div>
		<div class="timeline-item">
			<div class="timeline-dot"></div>
			<div class="timeline-date">Class of 2020</div>
			<div class="timeline-content">
				<h3>Junior High School</h3>
				<h4>Babag National High School</h4>
				<p>Graduated with Honors</p>
				<div class="achievement-badge">
					<i class="fa-solid fa-medal"></i>
					<span>With Honors</span>
				</div>
			</div>
		</div>
		<div class="timeline-item">
			<div class="timeline-dot"></div>
			<div class="timeline-date">Class of 2016</div>
			<div class="timeline-content">
				<h3>Elementary School</h3>
				<h4>Lapu-Lapu City Central Elementary School</h4>
				<p>Graduated with Honors</p>
				<div class="achievement-badge">
					<i class="fa-solid fa-medal"></i>
					<span>With Honors</span>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.education {
		background-color: var(--light);
	}

	.education .heading {
		color: var(--dark);
	}

	.education .heading span {
		-webkit-text-fill-color: var(--primary);
		color: var(--primary);
	}

	.timeline {
		position: relative;
		max-width: 1000px;
		margin: 0 auto;
		padding: 2rem 0;
	}

	.timeline::before {
		content: '';
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		width: 3px;
		height: 100%;
		background: var(--gradient);
	}

	.timeline-item {
		position: relative;
		margin-bottom: 3rem;
		width: 50%;
	}

	.timeline-item:nth-child(odd) {
		padding-right: 3rem;
		text-align: right;
	}

	.timeline-item:nth-child(even) {
		padding-left: 3rem;
		margin-left: 50%;
	}

	.timeline-dot {
		position: absolute;
		top: 15px;
		width: 22px;
		height: 22px;
		background: var(--primary);
		border-radius: 50%;
		border: 4px solid var(--white);
		box-shadow: 0 0 0 4px var(--secondary), 0 4px 10px rgba(162, 136, 166, 0.3);
		transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease;
		z-index: 2;
	}

	.timeline-item:hover .timeline-dot {
		transform: scale(1.25);
		box-shadow: 0 0 0 6px var(--secondary), 0 8px 20px rgba(162, 136, 166, 0.5);
	}

	.timeline-item:nth-child(odd) .timeline-dot {
		right: -11px;
	}

	.timeline-item:nth-child(even) .timeline-dot {
		left: -11px;
	}

	.timeline-date {
		font-size: 0.95rem;
		color: var(--primary);
		font-weight: 700;
		margin-bottom: 0.5rem;
		letter-spacing: 1px;
	}

	.timeline-content {
		background: var(--white);
		padding: 2rem;
		border-radius: 20px;
		box-shadow: 0 10px 30px rgba(162, 136, 166, 0.08);
		border: 1px solid rgba(162, 136, 166, 0.05);
		transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
	}

	.timeline-content:hover {
		transform: translateY(-6px);
		box-shadow: 0 20px 40px rgba(162, 136, 166, 0.15);
	}

	.timeline-content h3 {
		font-size: 1.35rem;
		color: var(--dark);
		font-weight: 700;
		margin-bottom: 0.5rem;
	}

	.timeline-content h4 {
		font-size: 1.05rem;
		color: var(--primary);
		margin-bottom: 0.75rem;
		font-weight: 600;
	}

	.timeline-content p {
		color: #666;
		margin-bottom: 1.25rem;
		font-size: 0.95rem;
	}

	.achievement-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: var(--light);
		padding: 0.5rem 1rem;
		border-radius: 20px;
		margin: 0.25rem;
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--primary);
		border: 1px solid rgba(162, 136, 166, 0.1);
		transition: all 0.3s ease;
		cursor: default;
	}

	.achievement-badge i {
		font-size: 0.9rem;
	}

	.achievement-badge:hover {
		background: var(--gradient);
		color: var(--white);
		border-color: transparent;
		transform: translateY(-2px);
		box-shadow: 0 5px 15px rgba(162, 136, 166, 0.2);
	}

	@media (max-width: 768px) {
		.timeline::before {
			left: 20px;
		}

		.timeline-item {
			width: 100%;
			padding-left: 3rem !important;
			padding-right: 0 !important;
			text-align: left !important;
			margin-left: 0 !important;
		}

		.timeline-dot {
			left: 9px !important;
			top: 18px;
		}
	}
</style>
