<section class="education-social" id="education-social">
	<div class="education-social-container">
		<!-- Education Section -->
		<div class="education-section">
			<h2 class="section-title">Education</h2>
			
			<!-- College -->
			<div class="education-card">
				<div class="education-icon">
					<i class="fa-solid fa-graduation-cap"></i>
				</div>
				<div class="education-content">
					<h3 class="degree">Bachelor of Science in Information Technology</h3>
					<p class="school">University of Cebu - Lapu-Lapu and Mandaue</p>
					<p class="year">Batch 2026</p>
					<div class="achievements">
						<span class="achievement-badge">Dean's Lister (1st Year to 4th Year)</span>
						<span class="achievement-badge">Academic Scholar</span>
					</div>
				</div>
			</div>

			<!-- Senior High School -->
			<div class="education-card">
				<div class="education-icon">
					<i class="fa-solid fa-school"></i>
				</div>
				<div class="education-content">
					<h3 class="degree">Senior High School</h3>
					<p class="school">University of Cebu - Lapu-Lapu and Mandaue</p>
					<p class="year">Batch 2022</p>
					<p class="strand">Science, Technology, Engineering, and Mathematics (STEM)</p>
					<div class="achievements">
						<span class="achievement-badge">With Honors</span>
						<span class="achievement-badge">Academic Scholar</span>
					</div>
				</div>
			</div>

			<!-- Junior High School -->
			<div class="education-card">
				<div class="education-icon">
					<i class="fa-solid fa-book"></i>
				</div>
				<div class="education-content">
					<h3 class="degree">Junior High School</h3>
					<p class="school">Babag National High School</p>
					<p class="year">Class of 2020</p>
					<div class="achievements">
						<span class="achievement-badge">With Honors</span>
					</div>
				</div>
			</div>

			<!-- Elementary -->
			<div class="education-card">
				<div class="education-icon">
					<i class="fa-solid fa-book-open"></i>
				</div>
				<div class="education-content">
					<h3 class="degree">Elementary School</h3>
					<p class="school">Lapu-Lapu City Central Elementary School</p>
					<p class="year">Class of 2016</p>
					<div class="achievements">
						<span class="achievement-badge">With Honors</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Social Media Section -->
		<div class="social-section">
			<h2 class="section-title">Connect With Me</h2>
			<div class="social-links">
				<a href="https://linkedin.com/in/gelmarie" target="_blank" rel="noopener noreferrer" class="social-link linkedin">
					<i class="fa-brands fa-linkedin"></i>
					<span>LinkedIn</span>
				</a>
				<a href="https://github.com/mykxttyjay" target="_blank" rel="noopener noreferrer" class="social-link github">
					<i class="fa-brands fa-github"></i>
					<span>GitHub</span>
				</a>
				<a href="https://instagram.com/angel_sabido" target="_blank" rel="noopener noreferrer" class="social-link instagram">
					<i class="fa-brands fa-instagram"></i>
					<span>Instagram</span>
				</a>
				<a href="mailto:sabidoangel.uc@gmail.com" class="social-link email">
					<i class="fa-solid fa-envelope"></i>
					<span>Email</span>
				</a>
			</div>
		</div>
	</div>
</section>

<style>
	.education-social {
		background-color: #FEF9E1;
		padding: 5rem 8%;
		position: relative;
		overflow: hidden;
	}

	.education-social::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			url("data:image/svg+xml,%3Csvg viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' result='noise' seed='2' /%3E%3CfeColorMatrix in='noise' type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100' height='100' fill='%23000000' filter='url(%23noiseFilter)' opacity='0.08'/%3E%3C/svg%3E");
		background-size: 100px 100px;
		pointer-events: none;
		z-index: 0;
		mix-blend-mode: overlay;
	}

	.education-social-container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		max-width: 1400px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}

	.section-title {
		font-size: 2.5rem;
		font-weight: 900;
		color: #A31D1D;
		margin-bottom: 2rem;
		font-family: 'Poppins', sans-serif;
		font-style: italic;
	}

	/* Education Styles */
	.education-card {
		background: white;
		padding: 2.5rem;
		border-radius: 15px;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
		display: flex;
		gap: 2rem;
		align-items: flex-start;
	}

	.education-icon {
		width: 80px;
		height: 80px;
		background: linear-gradient(135deg, #A31D1D 0%, #8B1515 100%);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		font-size: 2rem;
		flex-shrink: 0;
		box-shadow: 0 8px 20px rgba(163, 29, 29, 0.3);
	}

	.education-content {
		flex: 1;
	}

	.degree {
		font-size: 1.4rem;
		font-weight: 700;
		color: #A31D1D;
		margin-bottom: 0.5rem;
	}

	.school {
		font-size: 1.1rem;
		font-weight: 600;
		color: #5a3a5a;
		margin-bottom: 0.3rem;
	}

	.year {
		font-size: 0.95rem;
		color: #A31D1D;
		font-weight: 600;
		margin-bottom: 1rem;
	}

	.description {
		font-size: 0.95rem;
		line-height: 1.7;
		color: #5a3a5a;
	}

	/* Social Media Styles */
	.social-links {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}

	.social-link {
		background: white;
		padding: 1.5rem;
		border-radius: 15px;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
		display: flex;
		align-items: center;
		gap: 1rem;
		text-decoration: none;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
		color: #A31D1D;
		font-weight: 600;
		font-size: 1.1rem;
	}

	.social-link:hover {
		transform: translateY(-5px);
		box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
	}

	.social-link i {
		font-size: 2rem;
		width: 50px;
		height: 50px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		color: white;
	}

	.linkedin i {
		background: #0077B5;
	}

	.github i {
		background: #333;
	}

	.instagram i {
		background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
	}

	.email i {
		background: #A31D1D;
	}

	@media (max-width: 1024px) {
		.education-social-container {
			grid-template-columns: 1fr;
			gap: 3rem;
		}
	}

	@media (max-width: 768px) {
		.education-social {
			padding: 3rem 5%;
		}

		.section-title {
			font-size: 2rem;
		}

		.education-card {
			flex-direction: column;
			text-align: center;
			align-items: center;
		}

		.social-links {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 480px) {
		.education-social {
			padding: 2rem 4%;
		}

		.section-title {
			font-size: 1.8rem;
		}

		.degree {
			font-size: 1.2rem;
		}

		.social-link {
			padding: 1.2rem;
		}
	}
</style>
