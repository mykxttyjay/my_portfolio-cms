---
interface Props {
  type?: 'light-to-dark' | 'dark-to-light' | 'red-to-red' | 'smooth-red';
  class?: string;
}
const { type = 'light-to-dark', class: className } = Astro.props;
---

<div class={`divider ${type} ${className || ''}`}>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 80" preserveAspectRatio="none">
    <defs>
      <filter id="tear-shadow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur in="SourceAlpha" stdDeviation="3"/>
        <feOffset dx="0" dy="2" result="offsetblur"/>
        <feComponentTransfer>
          <feFuncA type="linear" slope="0.3"/>
        </feComponentTransfer>
        <feMerge>
          <feMergeNode/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
    </defs>
    <!-- Paper tear with jagged, organic edges -->
    <path d="M0,25 L8,22 L15,28 L22,20 L30,26 L38,19 L45,27 L52,21 L60,25 L68,18 L75,28 L82,20 L90,26 L98,19 L105,27 L112,22 L120,25 L128,18 L135,28 L142,20 L150,26 L158,19 L165,27 L172,21 L180,25 L188,17 L195,28 L202,20 L210,26 L218,19 L225,27 L232,22 L240,25 L248,18 L255,28 L262,20 L270,26 L278,19 L285,27 L292,21 L300,25 L308,17 L315,28 L322,20 L330,26 L338,19 L345,27 L352,22 L360,25 L368,18 L375,28 L382,20 L390,26 L398,19 L405,27 L412,21 L420,25 L428,17 L435,28 L442,20 L450,26 L458,19 L465,27 L472,22 L480,25 L488,18 L495,28 L502,20 L510,26 L518,19 L525,27 L532,21 L540,25 L548,17 L555,28 L562,20 L570,26 L578,19 L585,27 L592,22 L600,25 L608,18 L615,28 L622,20 L630,26 L638,19 L645,27 L652,21 L660,25 L668,17 L675,28 L682,20 L690,26 L698,19 L705,27 L712,22 L720,25 L728,18 L735,28 L742,20 L750,26 L758,19 L765,27 L772,21 L780,25 L788,17 L795,28 L802,20 L810,26 L818,19 L825,27 L832,22 L840,25 L848,18 L855,28 L862,20 L870,26 L878,19 L885,27 L892,21 L900,25 L908,17 L915,28 L922,20 L930,26 L938,19 L945,27 L952,22 L960,25 L968,18 L975,28 L982,20 L990,26 L998,19 L1005,27 L1012,21 L1020,25 L1028,17 L1035,28 L1042,20 L1050,26 L1058,19 L1065,27 L1072,22 L1080,25 L1088,18 L1095,28 L1102,20 L1110,26 L1118,19 L1125,27 L1132,21 L1140,25 L1148,17 L1155,28 L1162,20 L1170,26 L1178,19 L1185,27 L1192,22 L1200,25 L1208,18 L1215,28 L1222,20 L1230,26 L1238,19 L1245,27 L1252,21 L1260,25 L1268,17 L1275,28 L1282,20 L1290,26 L1298,19 L1305,27 L1312,22 L1320,25 L1328,18 L1335,28 L1342,20 L1350,26 L1358,19 L1365,27 L1372,21 L1380,25 L1388,17 L1395,28 L1402,20 L1410,26 L1418,19 L1425,27 L1432,22 L1440,25 L1440,80 L0,80 Z" class="divider-path" filter="url(#tear-shadow)"/>
  </svg>
</div>

<script>
  const initDividerAnimation = () => {
    const divider = document.querySelector('.smooth-red');
    if (!divider) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          divider.classList.add('scroll-active');
        }
      });
    }, { threshold: 0.5 });

    observer.observe(divider);
  };

  initDividerAnimation();
  document.addEventListener('astro:page-load', initDividerAnimation);
</script>

<style>
  .divider {
    width: 100%;
    line-height: 0;
    margin: 0;
    padding: 0;
    position: relative;
    z-index: 5;
    background-color: transparent;
  }

  svg {
    display: block;
    width: 100%;
    height: 50px;
    margin-top: -1px;
    margin-bottom: -1px;
  }

  .light-to-dark {
    /* Above is light (cream), below is dark (red). */
    /* The SVG is filled with red color. */
    background: linear-gradient(to bottom, #FEF9E1 0%, #FEF9E1 50%, #A31D1D 100%);
  }

  .light-to-dark .divider-path {
    fill: #A31D1D; /* Section Red */
  }

  .red-to-red {
    background: linear-gradient(to bottom, #8F1D21 0%, #8F1D21 50%, #FEF9E1 100%);
  }

  .red-to-red .divider-path {
    fill: #FEF9E1;
  }

  /* Smooth transition for same color sections (Skills, Projects, Experience) */
  .smooth-cream {
    background: #FEF9E1;
  }

  .smooth-cream .divider-path {
    fill: #FEF9E1;
    transition: all 0.6s ease-out;
  }

  .smooth-cream.scroll-active .divider-path {
    animation: wave-connect 0.8s ease-out forwards;
  }

  /* Cream to red transition (Experience to Contact) */
  .cream-to-red {
    background: linear-gradient(to bottom, #FEF9E1 0%, #FEF9E1 50%, #8F1D21 100%);
  }

  .cream-to-red .divider-path {
    fill: #8F1D21;
  }

  .dark-to-light {
    /* Above is dark (red), below is light (cream). */
    /* The SVG is filled with cream color. */
    background-color: #A31D1D;
  }

  .dark-to-light .divider-path {
    fill: #FEF9E1; /* Cream */
  }

  /* Special style to match Home section's dark bottom vignette */
  .home-divider {
    background-color: #5A0E11 !important;
  }
</style>
