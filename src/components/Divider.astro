---
interface Props {
  type?: 'light-to-dark' | 'dark-to-light' | 'red-to-red' | 'smooth-red';
  class?: string;
}
const { type = 'light-to-dark', class: className } = Astro.props;
---

<div class={`divider ${type} ${className || ''}`}>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 100" preserveAspectRatio="none">
    <path d="M0,30 L20,35 L35,28 L55,40 L70,32 L90,38 L110,25 L130,35 L145,28 L165,40 L185,30 L200,38 L220,32 L240,40 L255,28 L275,35 L295,30 L310,38 L330,32 L350,40 L365,28 L385,35 L405,30 L420,38 L440,32 L460,40 L475,28 L495,35 L515,30 L530,38 L550,32 L570,40 L585,28 L605,35 L625,30 L640,38 L660,32 L680,40 L695,28 L715,35 L735,30 L750,38 L770,32 L790,40 L805,28 L825,35 L845,30 L860,38 L880,32 L900,40 L915,28 L935,35 L955,30 L970,38 L990,32 L1010,40 L1025,28 L1045,35 L1065,30 L1080,38 L1100,32 L1120,40 L1135,28 L1155,35 L1175,30 L1190,38 L1210,32 L1230,40 L1245,28 L1265,35 L1285,30 L1300,38 L1320,32 L1340,40 L1355,28 L1375,35 L1395,30 L1410,38 L1430,32 L1440,35 L1440,100 L0,100 Z" class="divider-path"/>
  </svg>
</div>

<script>
  const initDividerAnimation = () => {
    const divider = document.querySelector('.smooth-red');
    if (!divider) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          divider.classList.add('scroll-active');
        }
      });
    }, { threshold: 0.5 });

    observer.observe(divider);
  };

  initDividerAnimation();
  document.addEventListener('astro:page-load', initDividerAnimation);
</script>

<style>
  .divider {
    width: 100%;
    line-height: 0;
    margin: 0;
    padding: 0;
    position: relative;
    z-index: 5;
    background-color: transparent;
  }

  svg {
    display: block;
    width: 100%;
    height: 60px;
    margin-top: -1px;
    margin-bottom: -1px;
  }

  .light-to-dark {
    /* Above is light (cream), below is dark (red). */
    /* The SVG is filled with red color. */
    background: linear-gradient(to bottom, #FEF9E1 0%, #FEF9E1 50%, #A31D1D 100%);
  }

  .light-to-dark .divider-path {
    fill: #A31D1D; /* Section Red */
  }

  .red-to-red {
    background: linear-gradient(to bottom, #8F1D21 0%, #8F1D21 50%, #FEF9E1 100%);
  }

  .red-to-red .divider-path {
    fill: #FEF9E1;
  }

  /* Smooth transition for same color sections (Skills, Projects, Experience) */
  .smooth-cream {
    background: #FEF9E1;
  }

  .smooth-cream .divider-path {
    fill: #FEF9E1;
    transition: all 0.6s ease-out;
  }

  .smooth-cream.scroll-active .divider-path {
    animation: wave-connect 0.8s ease-out forwards;
  }

  /* Cream to red transition (Experience to Contact) */
  .cream-to-red {
    background: linear-gradient(to bottom, #FEF9E1 0%, #FEF9E1 50%, #8F1D21 100%);
  }

  .cream-to-red .divider-path {
    fill: #8F1D21;
  }

  .dark-to-light {
    /* Above is dark (red), below is light (cream). */
    /* The SVG is filled with cream color. */
    background-color: #A31D1D;
  }

  .dark-to-light .divider-path {
    fill: #FEF9E1; /* Cream */
  }

  /* Special style to match Home section's dark bottom vignette */
  .home-divider {
    background-color: #5A0E11 !important;
  }
</style>
